<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkForceGov</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
        body { 
            display: flex; 
            flex-direction: column; 
            min-height: 100vh;
            /* Add padding so content doesn't go under the fixed header */
            padding-top: 72px; 
        }
        main { flex: 1; }
        .navbar-brand { font-weight: bold; color: #2c3e50 !important; }
        
        /* Smooth scroll for the "Portals" anchor link */
        html { scroll-behavior: smooth; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3 fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🏛️ WorkForceGov</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold px-3" href="@Url.Action("Index", "Home")#actors">Portals</a>
                        </li>

                        @if (Context.Session.GetString("UserRole") != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-dark">Welcome, @Context.Session.GetString("UserName")</span>
                            </li>
                            @if (Context.Session.GetString("UserRole") == "Employer")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-semibold px-3" asp-controller="Employer" asp-action="Dashboard">Dashboard</a>
                                </li>
                            }
                            else if (Context.Session.GetString("UserRole") == "Citizen")
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark fw-semibold px-3" asp-controller="Citizen" asp-action="Dashboard">Dashboard</a>
                                </li>
                            }
                            <li class="nav-item ms-lg-2">
                                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger px-4 fw-bold">Logout</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-semibold px-3" asp-controller="Employer" asp-action="Register">Employer Registration</a>
                            </li>
                            <li class="nav-item ms-lg-2">
                                <a asp-controller="Account" asp-action="Login" class="btn btn-primary px-4 fw-bold shadow-sm">Sign In</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-4 mt-auto">
        <div class="container text-center">
            <p class="mb-0">&copy; 2026 WorkForceGov | Employment & Labor Governance System</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>