@model WorkForceGovProject.Models.EmploymentProgram
@{
    ViewData["Title"] = "Create Program";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Create New Program</h2>
                <p class="text-muted">Add a new employment program to the system</p>
            </div>
            <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="btn btn-secondary shadow-sm px-4">
                <i class="bi bi-arrow-left"></i> Back to Programs
            </a>
        </div>

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <form asp-action="CreateProgram" asp-controller="ProgramManager" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <!-- Program Title -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Title" class="form-label fw-bold">Program Title <span class="text-danger">*</span></label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="Enter program title" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Program Description -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Description" class="form-label fw-bold">Description <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control" rows="4" placeholder="Enter detailed program description"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Start Date -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="StartDate" class="form-label fw-bold">Start Date <span class="text-danger">*</span></label>
                            <input asp-for="StartDate" type="date" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- End Date -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="EndDate" class="form-label fw-bold">End Date <span class="text-danger">*</span></label>
                            <input asp-for="EndDate" type="date" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Budget -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Budget" class="form-label fw-bold">Program Budget <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Budget" type="number" step="0.01" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Budget" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Status" class="form-label fw-bold">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-select">
                                <option value="">-- Select Status --</option>
                                <option value="Active" selected>Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Pending">Pending</option>
                                <option value="Completed">Completed</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Information Box -->
                <div class="alert alert-info d-flex align-items-center mt-4" role="alert">
                    <i class="bi bi-info-circle-fill me-2" style="font-size: 1.5rem;"></i>
                    <div>
                        <strong>Note:</strong> All fields marked with <span class="text-danger">*</span> are required. 
                        Make sure to set realistic dates and budget allocations.
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                    <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="btn btn-lg btn-outline-secondary px-5">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-lg btn-primary px-5 shadow-sm">
                        <i class="bi bi-check-circle"></i> Create Program
                    </button>
                </div>
            </form>
        </div>

        <!-- Help Section -->
        <div class="bg-light rounded-3 border p-4 mt-4">
            <h5 class="fw-bold mb-3">
                <i class="bi bi-question-circle text-primary"></i> Program Creation Guidelines
            </h5>
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Title:</strong> Use a clear and descriptive name
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Description:</strong> Provide comprehensive program details
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Dates:</strong> Ensure end date is after start date
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Budget:</strong> Enter the total allocated amount
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Status:</strong> New programs are typically set to "Active"
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Review:</strong> Double-check all information before submitting
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

<style>
    .form-label {
        color: #1e293b;
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
    }

    .form-control,
    .form-select {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 0.75rem;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

    .form-control:focus,
    .form-select:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 0.2rem rgba(59, 130, 246, 0.15);
    }

    .form-control-lg {
        padding: 1rem;
        font-size: 1.1rem;
    }

    .input-group-text {
        background-color: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px 0 0 8px;
        font-weight: 600;
        color: #64748b;
    }

    .btn {
        border-radius: 8px;
        font-weight: 600;
        transition: all 0.2s ease;
    }

    .btn-primary {
        background-color: #3b82f6;
        border-color: #3b82f6;
    }

    .btn-primary:hover {
        background-color: #2563eb;
        border-color: #2563eb;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
    }

    .btn-outline-secondary:hover {
        transform: translateY(-2px);
    }

    .alert-info {
        background-color: #dbeafe;
        border: 1px solid #93c5fd;
        color: #1e40af;
        border-radius: 8px;
    }

    .text-danger {
        font-size: 0.875rem;
        font-weight: 500;
    }

    textarea.form-control {
        resize: vertical;
        min-height: 100px;
    }

    .list-unstyled li {
        padding-left: 0;
    }

    .bi-check-circle-fill {
        font-size: 0.875rem;
    }
</style>
