@model IEnumerable<WorkForceGovProject.Models.EmploymentProgram>
@{
    ViewData["Title"] = "Program Management";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/ProgramManagement.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a href="#" class="active">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Employment Programs</h2>
                <p class="text-muted">Manage workforce development programs</p>
            </div>
            <a asp-action="CreateProgram" asp-controller="ProgramManager" class="btn btn-primary shadow-sm px-4 fw-bold">
                <i class="bi bi-plus-circle"></i> Create New Program
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="bg-white rounded-3 border shadow-sm">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Program ID</th>
                                <th class="py-3">Title</th>
                                <th class="py-3">Start Date</th>
                                <th class="py-3">End Date</th>
                                <th class="py-3">Budget</th>
                                <th class="py-3">Status</th>
                                <th class="py-3 text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var program in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-bold text-primary">#@program.ProgramID</td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@program.Title</div>
                                        <small class="text-muted">@(program.Description.Length > 50 ? program.Description.Substring(0, 50) + "..." : program.Description)</small>
                                    </td>
                                    <td class="py-3">@program.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3">@program.EndDate.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3 fw-bold">@program.Budget.ToString("C")</td>
                                    <td class="py-3">
                                        @if (program.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (program.Status == "Inactive")
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                        else if (program.Status == "Completed")
                                        {
                                            <span class="badge bg-info">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning">@program.Status</span>
                                        }
                                    </td>
                                    <td class="py-3 text-center">
                                        <div class="btn-group" role="group">
                                            <a asp-action="EditProgram" asp-controller="ProgramManager" asp-route-id="@program.ProgramID" 
                                               class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i> Edit
                                            </a>
                                            <a asp-action="DeleteProgram" asp-controller="ProgramManager" asp-route-id="@program.ProgramID" 
                                               class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i> Delete
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-folder-x" style="font-size: 4rem; color: #cbd5e1;"></i>
                    </div>
                    <h4 class="text-muted mb-3">No Programs Found</h4>
                    <p class="text-muted mb-4">You haven't created any employment programs yet.</p>
                    <a asp-action="CreateProgram" asp-controller="ProgramManager" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle"></i> Create Your First Program
                    </a>
                </div>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="mt-4">
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="stat-card">
                            <small class="text-uppercase text-muted fw-bold">Total Programs</small>
                            <p class="h4 mb-0 mt-2 fw-bold text-dark">@Model.Count()</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card">
                            <small class="text-uppercase text-muted fw-bold">Active Programs</small>
                            <p class="h4 mb-0 mt-2 fw-bold text-success">@Model.Count(p => p.Status == "Active")</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card">
                            <small class="text-uppercase text-muted fw-bold">Total Budget</small>
                            <p class="h4 mb-0 mt-2 fw-bold text-primary">@Model.Sum(p => p.Budget).ToString("C")</p>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card">
                            <small class="text-uppercase text-muted fw-bold">Avg. Budget</small>
                            <p class="h4 mb-0 mt-2 fw-bold text-info">@Model.Average(p => p.Budget).ToString("C")</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
    }

    .table tbody tr {
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: #f8fafc;
    }

    .btn-group .btn {
        padding: 0.375rem 0.75rem;
    }
</style>
