@model IEnumerable<WorkForceGovProject.Models.Resource>
@{
    ViewData["Title"] = "Resource Management";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a href="#" class="active">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Resource Management</h2>
                <p class="text-muted">Track and manage program resources</p>
            </div>
            <a asp-action="CreateResource" asp-controller="ProgramManager" class="btn btn-primary shadow-sm px-4 fw-bold">
                <i class="bi bi-plus-circle"></i> Create New Resource
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <!-- Summary Cards -->
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="icon text-primary">📦</div>
                        <small class="text-uppercase text-muted fw-bold">Total Resources</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@Model.Count()</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="icon text-success">✅</div>
                        <small class="text-uppercase text-muted fw-bold">Available</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-success">@Model.Count(r => r.Status == "Available")</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="stat-card">
                        <div class="icon text-warning">📊</div>
                        <small class="text-uppercase text-muted fw-bold">Total Quantity</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@Model.Sum(r => r.Quantity)</p>
                    </div>
                </div>
            </div>

            <!-- Resources Table -->
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Resource ID</th>
                                <th class="py-3">Type</th>
                                <th class="py-3">Program</th>
                                <th class="py-3 text-center">Quantity</th>
                                <th class="py-3 text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var resource in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-bold text-primary">#@resource.ResourceID</td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@resource.Type</div>
                                    </td>
                                    <td class="py-3">
                                        @if (resource.EmploymentProgram != null)
                                        {
                                            <span class="badge bg-info">#@resource.ProgramID - @resource.EmploymentProgram.Title</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">#@resource.ProgramID</span>
                                        }
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="badge bg-primary">@resource.Quantity</span>
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (resource.Status == "Available")
                                        {
                                            <span class="badge bg-success">Available</span>
                                        }
                                        else if (resource.Status == "In Use")
                                        {
                                            <span class="badge bg-warning">In Use</span>
                                        }
                                        else if (resource.Status == "Depleted")
                                        {
                                            <span class="badge bg-danger">Depleted</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@resource.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-box-seam" style="font-size: 4rem; color: #cbd5e1;"></i>
                    </div>
                    <h4 class="text-muted mb-3">No Resources Found</h4>
                    <p class="text-muted mb-4">No resources have been allocated yet.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
    }

    .table tbody tr {
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: #f8fafc;
    }
</style>
