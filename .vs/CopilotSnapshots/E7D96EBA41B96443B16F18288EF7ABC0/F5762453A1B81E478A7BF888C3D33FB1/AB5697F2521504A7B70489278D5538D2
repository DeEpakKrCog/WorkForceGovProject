@model IEnumerable<WorkForceGovProject.Models.EmploymentProgram>
@{
    ViewData["Title"] = "Performance Tracking";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/PerformanceTracking.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a href="#" class="active">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Performance Tracking</h2>
                <p class="text-muted">Monitor program performance metrics and KPIs</p>
            </div>
            <button class="btn btn-info shadow-sm px-4 fw-bold" onclick="window.print()">
                <i class="bi bi-download"></i> Export Data
            </button>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            var totalPrograms = Model.Count();
            var activePrograms = Model.Count(p => p.Status == "Active");
            var totalTrainings = Model.Sum(p => p.Trainings?.Count ?? 0);
            var totalBeneficiaries = Model.Sum(p => p.Benefits?.Select(b => b.CitizenID).Distinct().Count() ?? 0);

            <!-- Performance Summary Cards -->
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-primary">📋</div>
                        <small class="text-uppercase text-muted fw-bold">Active Programs</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@activePrograms</p>
                        <small class="text-muted">Out of @totalPrograms total</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-info">🎓</div>
                        <small class="text-uppercase text-muted fw-bold">Total Trainings</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@totalTrainings</p>
                        <small class="text-muted">Across all programs</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-success">👥</div>
                        <small class="text-uppercase text-muted fw-bold">Beneficiaries</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@totalBeneficiaries</p>
                        <small class="text-muted">Citizens helped</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-warning">⭐</div>
                        <small class="text-uppercase text-muted fw-bold">Success Rate</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@((totalPrograms > 0 ? (activePrograms * 100.0 / totalPrograms) : 0).ToString("0.0"))%</p>
                        <small class="text-muted">Program completion</small>
                    </div>
                </div>
            </div>

            <!-- Performance Metrics Table -->
            <div class="bg-white rounded-3 border shadow-sm mb-4">
                <div class="p-4 border-bottom">
                    <h5 class="fw-bold mb-0">Program Performance Metrics</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Program</th>
                                <th class="py-3 text-center">Trainings</th>
                                <th class="py-3 text-center">Beneficiaries</th>
                                <th class="py-3 text-center">Budget Utilization</th>
                                <th class="py-3 text-center">Duration</th>
                                <th class="py-3 text-center">Status</th>
                                <th class="py-3 text-center">Performance</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var program in Model)
                            {
                                var trainingCount = program.Trainings?.Count ?? 0;
                                var beneficiaryCount = program.Benefits?.Select(b => b.CitizenID).Distinct().Count() ?? 0;
                                var spent = program.Benefits?.Sum(b => b.Amount) ?? 0;
                                var utilization = program.Budget > 0 ? (spent / program.Budget * 100) : 0;
                                var duration = (program.EndDate - program.StartDate).Days;
                                var daysRemaining = (program.EndDate - DateTime.Now).Days;
                                
                                // Calculate performance score (simple metric based on trainings and beneficiaries)
                                var performanceScore = (trainingCount * 10) + (beneficiaryCount * 5);
                                var performanceLevel = performanceScore > 100 ? "Excellent" : performanceScore > 50 ? "Good" : performanceScore > 20 ? "Average" : "Low";

                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="fw-bold text-dark">#@program.ProgramID - @program.Title</div>
                                        <small class="text-muted">@program.StartDate.ToString("MMM yyyy") - @program.EndDate.ToString("MMM yyyy")</small>
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="badge bg-info">@trainingCount</span>
                                    </td>
                                    <td class="py-3 text-center">
                                        <span class="badge bg-success">@beneficiaryCount</span>
                                    </td>
                                    <td class="py-3 text-center">
                                        <div class="performance-metric">
                                            <span class="fw-bold @(utilization > 80 ? "text-danger" : utilization > 50 ? "text-warning" : "text-success")">
                                                @utilization.ToString("0.0")%
                                            </span>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        <div>
                                            <span class="fw-bold">@duration days</span><br />
                                            @if (daysRemaining > 0)
                                            {
                                                <small class="text-muted">@daysRemaining days left</small>
                                            }
                                            else
                                            {
                                                <small class="text-danger">Ended</small>
                                            }
                                        </div>
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (program.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (program.Status == "Completed")
                                        {
                                            <span class="badge bg-info">Completed</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@program.Status</span>
                                        }
                                    </td>
                                    <td class="py-3 text-center">
                                        @if (performanceLevel == "Excellent")
                                        {
                                            <span class="badge bg-success">⭐ Excellent</span>
                                        }
                                        else if (performanceLevel == "Good")
                                        {
                                            <span class="badge bg-primary">👍 Good</span>
                                        }
                                        else if (performanceLevel == "Average")
                                        {
                                            <span class="badge bg-warning">📊 Average</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">📉 Low</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Program Details Grid -->
            <div class="row g-4">
                @foreach (var program in Model)
                {
                    var trainingCount = program.Trainings?.Count ?? 0;
                    var activeTrainings = program.Trainings?.Count(t => t.Status == "Active") ?? 0;
                    var beneficiaryCount = program.Benefits?.Select(b => b.CitizenID).Distinct().Count() ?? 0;
                    var totalBenefitsAmount = program.Benefits?.Sum(b => b.Amount) ?? 0;

                    <div class="col-md-6">
                        <div class="program-detail-card">
                            <div class="card-header">
                                <h5 class="fw-bold mb-1">@program.Title</h5>
                                <small class="text-muted">Program ID: #@program.ProgramID</small>
                            </div>
                            <div class="card-body">
                                <div class="metric-row">
                                    <div class="metric-item">
                                        <span class="metric-label">Trainings</span>
                                        <span class="metric-value text-info">@trainingCount (@activeTrainings active)</span>
                                    </div>
                                    <div class="metric-item">
                                        <span class="metric-label">Beneficiaries</span>
                                        <span class="metric-value text-success">@beneficiaryCount citizens</span>
                                    </div>
                                </div>
                                <div class="metric-row">
                                    <div class="metric-item">
                                        <span class="metric-label">Budget</span>
                                        <span class="metric-value text-primary">@program.Budget.ToString("C")</span>
                                    </div>
                                    <div class="metric-item">
                                        <span class="metric-label">Benefits Paid</span>
                                        <span class="metric-value text-danger">@totalBenefitsAmount.ToString("C")</span>
                                    </div>
                                </div>
                                <div class="progress mt-3" style="height: 8px;">
                                    @{
                                        var progressPercent = program.Budget > 0 ? (totalBenefitsAmount / program.Budget * 100) : 0;
                                    }
                                    <div class="progress-bar @(progressPercent > 80 ? "bg-danger" : progressPercent > 50 ? "bg-warning" : "bg-success")" 
                                         style="width: @progressPercent%"></div>
                                </div>
                                <div class="d-flex justify-content-between mt-2">
                                    <small class="text-muted">Budget Utilization: @progressPercent.ToString("0.0")%</small>
                                    <small class="text-muted">Status: <strong>@program.Status</strong></small>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-graph-up" style="font-size: 4rem; color: #cbd5e1;"></i>
                    </div>
                    <h4 class="text-muted mb-3">No Performance Data Available</h4>
                    <p class="text-muted mb-4">Create programs to start tracking performance metrics.</p>
                    <a asp-action="CreateProgram" asp-controller="ProgramManager" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle"></i> Create Program
                    </a>
                </div>
            </div>
        }
    </div>
</div>
