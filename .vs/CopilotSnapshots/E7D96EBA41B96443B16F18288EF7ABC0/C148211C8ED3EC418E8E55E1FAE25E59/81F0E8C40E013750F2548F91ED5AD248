@model IEnumerable<WorkForceGovProject.Models.EmploymentProgram>
@{
    ViewData["Title"] = "Budget Monitoring";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a href="#" class="active">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Budget Monitoring</h2>
                <p class="text-muted">Track program budgets and financial allocation</p>
            </div>
            <button class="btn btn-success shadow-sm px-4 fw-bold" onclick="window.print()">
                <i class="bi bi-printer"></i> Print Report
            </button>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            var totalBudget = Model.Sum(p => p.Budget);
            var totalSpent = Model.Sum(p => p.Benefits?.Sum(b => b.Amount) ?? 0);
            var totalRemaining = totalBudget - totalSpent;
            var utilizationPercentage = totalBudget > 0 ? (totalSpent / totalBudget * 100) : 0;

            <!-- Summary Cards -->
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-primary">💰</div>
                        <small class="text-uppercase text-muted fw-bold">Total Budget</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@totalBudget.ToString("C")</p>
                        <small class="text-muted">Allocated Funds</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-danger">📉</div>
                        <small class="text-uppercase text-muted fw-bold">Total Spent</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-danger">@totalSpent.ToString("C")</p>
                        <small class="text-muted">Benefits Distributed</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-success">💵</div>
                        <small class="text-uppercase text-muted fw-bold">Remaining</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-success">@totalRemaining.ToString("C")</p>
                        <small class="text-muted">Available Funds</small>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-warning">📊</div>
                        <small class="text-uppercase text-muted fw-bold">Utilization</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-warning">@utilizationPercentage.ToString("0.00")%</p>
                        <small class="text-muted">Budget Used</small>
                    </div>
                </div>
            </div>

            <!-- Overall Budget Progress -->
            <div class="bg-white rounded-3 border shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Overall Budget Utilization</h5>
                <div class="progress" style="height: 30px;">
                    <div class="progress-bar @(utilizationPercentage > 90 ? "bg-danger" : utilizationPercentage > 70 ? "bg-warning" : "bg-success")" 
                         role="progressbar" 
                         style="width: @utilizationPercentage%;" 
                         aria-valuenow="@utilizationPercentage" 
                         aria-valuemin="0" 
                         aria-valuemax="100">
                        <span class="fw-bold">@utilizationPercentage.ToString("0.00")%</span>
                    </div>
                </div>
                <div class="d-flex justify-content-between mt-2">
                    <small class="text-muted">Allocated: @totalBudget.ToString("C")</small>
                    <small class="text-muted">Spent: @totalSpent.ToString("C")</small>
                    <small class="text-muted">Remaining: @totalRemaining.ToString("C")</small>
                </div>
            </div>

            <!-- Program Budget Details -->
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="p-4 border-bottom">
                    <h5 class="fw-bold mb-0">Program Budget Breakdown</h5>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Program</th>
                                <th class="py-3">Allocated Budget</th>
                                <th class="py-3">Spent (Benefits)</th>
                                <th class="py-3">Remaining</th>
                                <th class="py-3">Utilization</th>
                                <th class="py-3">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var program in Model)
                            {
                                var allocated = program.Budget;
                                var spent = program.Benefits?.Sum(b => b.Amount) ?? 0;
                                var remaining = allocated - spent;
                                var utilization = allocated > 0 ? (spent / allocated * 100) : 0;

                                <tr>
                                    <td class="px-4 py-3">
                                        <div class="fw-bold text-dark">#@program.ProgramID - @program.Title</div>
                                        <small class="text-muted">@program.Status</small>
                                    </td>
                                    <td class="py-3 fw-bold text-primary">@allocated.ToString("C")</td>
                                    <td class="py-3 fw-bold text-danger">@spent.ToString("C")</td>
                                    <td class="py-3 fw-bold text-success">@remaining.ToString("C")</td>
                                    <td class="py-3">
                                        <div class="d-flex align-items-center">
                                            <div class="progress flex-grow-1 me-2" style="height: 20px; min-width: 100px;">
                                                <div class="progress-bar @(utilization > 90 ? "bg-danger" : utilization > 70 ? "bg-warning" : "bg-success")" 
                                                     role="progressbar" 
                                                     style="width: @utilization%;" 
                                                     aria-valuenow="@utilization" 
                                                     aria-valuemin="0" 
                                                     aria-valuemax="100">
                                                </div>
                                            </div>
                                            <span class="fw-bold" style="min-width: 50px;">@utilization.ToString("0.0")%</span>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        @if (utilization < 50)
                                        {
                                            <span class="badge bg-success">Healthy</span>
                                        }
                                        else if (utilization < 80)
                                        {
                                            <span class="badge bg-info">Moderate</span>
                                        }
                                        else if (utilization < 95)
                                        {
                                            <span class="badge bg-warning">High</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Critical</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Budget Alerts -->
            <div class="mt-4">
                <div class="bg-white rounded-3 border shadow-sm p-4">
                    <h5 class="fw-bold mb-3">
                        <i class="bi bi-exclamation-triangle-fill text-warning"></i> Budget Alerts
                    </h5>
                    @{
                        var hasAlerts = false;
                        foreach (var program in Model)
                        {
                            var spent = program.Benefits?.Sum(b => b.Amount) ?? 0;
                            var utilization = program.Budget > 0 ? (spent / program.Budget * 100) : 0;

                            if (utilization > 80)
                            {
                                hasAlerts = true;
                                <div class="alert alert-@(utilization > 95 ? "danger" : "warning") d-flex align-items-center mb-2" role="alert">
                                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                                    <div>
                                        <strong>@program.Title</strong> has used <strong>@utilization.ToString("0.0")%</strong> of its allocated budget.
                                        @if (utilization > 95)
                                        {
                                            <span>Immediate action required!</span>
                                        }
                                        else
                                        {
                                            <span>Please monitor spending closely.</span>
                                        }
                                    </div>
                                </div>
                            }
                        }

                        if (!hasAlerts)
                        {
                            <div class="alert alert-success d-flex align-items-center" role="alert">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <div>All programs are within healthy budget utilization limits.</div>
                            </div>
                        }
                    }
                </div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-cash-stack" style="font-size: 4rem; color: #cbd5e1;"></i>
                    </div>
                    <h4 class="text-muted mb-3">No Budget Data Available</h4>
                    <p class="text-muted mb-4">Create programs to start tracking budgets.</p>
                    <a asp-action="CreateProgram" asp-controller="ProgramManager" class="btn btn-primary px-4">
                        <i class="bi bi-plus-circle"></i> Create Program
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .progress {
        border-radius: 8px;
        background-color: #e5e7eb;
    }

    .progress-bar {
        border-radius: 8px;
        transition: width 0.6s ease;
        font-size: 0.875rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
    }

    .table tbody tr {
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: #f8fafc;
    }

    .alert {
        border-radius: 8px;
        border: none;
    }

    @@media print {
        .sidebar-nav,
        .btn {
            display: none;
        }

        .main-content {
            padding: 0;
        }
    }
</style>
