using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Http;
using WorkForceGovProject.Data;
using WorkForceGovProject.Models;
using System.Linq;

namespace WorkForceGovProject.Controllers
{
    public class CitizenController : Controller
    {
        private readonly ApplicationDbContext _context;

        public CitizenController(ApplicationDbContext context)
        {
            _context = context;
        }

        // 1. DASHBOARD ACTION
        public IActionResult Dashboard()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");
            if (userId == null) return RedirectToAction("Login", "Account");

            var citizen = _context.Citizens.FirstOrDefault(c => c.UserId == userId);

            if (citizen == null)
            {
                citizen = new Citizen
                {
                    UserId = userId.Value,
                    FullName = HttpContext.Session.GetString("UserName") ?? "Citizen User",
                    Email = HttpContext.Session.GetString("UserEmail") ?? "",
                    ActiveApplications = 0,
                    AccountBalance = 0.00m,
                    DocumentStatus = "Pending",
                    NewJobMatches = 0
                };

                _context.Citizens.Add(citizen);
                _context.SaveChanges();
            }

            return View(citizen);
        }

        // 2. PROFILE ACTION (This fixes the "not rendering" issue)
        public IActionResult Profile()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");
            if (userId == null) return RedirectToAction("Login", "Account");

            // Fetch the citizen linked to the logged-in user
            var citizen = _context.Citizens.FirstOrDefault(c => c.UserId == userId);

            if (citizen == null) return RedirectToAction("Dashboard");

            return View(citizen);
        }

        // 3. UPDATE PROFILE ACTION (To save form data)
        [HttpPost]
        [ValidateAntiForgeryToken]
        public IActionResult UpdateProfile(Citizen model)
        {
            var citizenInDb = _context.Citizens.FirstOrDefault(c => c.Id == model.Id);

            if (citizenInDb != null)
            {
                // Update specific fields
                citizenInDb.FullName = model.FullName;
                citizenInDb.Address = model.Address;
                citizenInDb.Gender = model.Gender;
                citizenInDb.DOB = model.DOB;

                _context.SaveChanges();
                TempData["SuccessMessage"] = "Profile updated successfully!";
            }

            return RedirectToAction("Profile");
        }
    }
}