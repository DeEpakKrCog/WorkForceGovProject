@model IEnumerable<WorkForceGovProject.Models.CitizenDocument>
@{
    ViewData["Title"] = "Verification Docs";
}

<div class="main-content container py-5">
    <div class="card shadow-sm mb-5 border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0">📁 Upload New Document</h5>
        </div>
        <div class="card-body">
            <form asp-action="UploadDoc" method="post" enctype="multipart/form-data" class="row g-3">
                <div class="col-md-5">
                    <label class="form-label fw-bold">Document Type</label>
                    <select name="DocType" class="form-select" required>
                        [cite: 139]
                        <option value="Identity Proof">Identity Proof</option> [cite: 78]
                        <option value="Qualification">Qualification Certificate</option> [cite: 79]
                        <option value="Resume">Resume</option> [cite: 80]
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold">Select File</label>
                    <input type="file" name="file" class="form-control" required />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100 fw-bold">Upload</button>
                </div>
            </form>
        </div>
    </div>

    <h4 class="fw-bold mb-3">Your Uploaded Documents</h4>
    <div class="bg-white rounded shadow-sm border overflow-hidden">
        <table class="table table-hover mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="px-4">Type</th>
                    <th>Uploaded Date</th> [cite: 143]
                    <th>Status</th> [cite: 144]
                    <th class="text-end px-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var doc in Model)
                {
                    <tr>
                        <td class="px-4 fw-bold">@doc.DocType</td>
                        <td>@doc.UploadedDate.ToString("D")</td>
                        <td>
                            <span class="badge @(doc.VerificationStatus == "Verified" ? "bg-success" : "bg-warning text-dark")">
                                @doc.VerificationStatus
                            </span>
                        </td>
                        <td class="text-end px-4">
                            <a href="@doc.FileURL" target="_blank" class="btn btn-sm btn-outline-secondary">View File</a> [cite: 141]
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>