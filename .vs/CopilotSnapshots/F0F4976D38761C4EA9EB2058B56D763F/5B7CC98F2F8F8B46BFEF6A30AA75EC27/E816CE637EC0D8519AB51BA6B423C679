using WorkForceGovProject.Models;
using WorkForceGovProject.Interfaces;
using WorkForceGovProject.Interfaces;

namespace WorkForceGovProject.Services.Implementations
{
    /// <summary>
    /// Notification Service Implementation
    /// Handles notification operations
    /// </summary>
    public class NotificationService : INotificationService
    {
        private readonly IUnitOfWork _unitOfWork;
        private readonly ILogger<NotificationService> _logger;

        public NotificationService(IUnitOfWork unitOfWork, ILogger<NotificationService> logger)
        {
            _unitOfWork = unitOfWork;
            _logger = logger;
        }

        public async Task<IEnumerable<Notification>> GetUserNotificationsAsync(int userId)
        {
            return await _unitOfWork.NotificationRepository.GetUserNotificationsAsync(userId);
        }

        public async Task<IEnumerable<Notification>> GetUnreadNotificationsAsync(int userId)
        {
            return await _unitOfWork.NotificationRepository.GetUnreadNotificationsAsync(userId);
        }

        public async Task<int> GetUnreadCountAsync(int userId)
        {
            return await _unitOfWork.NotificationRepository.GetUnreadCountAsync(userId);
        }

        public async Task<(bool Success, Notification Notification)> CreateNotificationAsync(int userId, string message, string category, int? entityId, string entityType)
        {
            try
            {
                var notification = new Notification
                {
                    UserId = userId,
                    Message = message,
                    Category = category,
                    EntityId = entityId,
                    EntityType = entityType,
                    CreatedDate = DateTime.Now,
                    IsRead = false,
                    Status = "Active"
                };

                await _unitOfWork.Notifications.AddAsync(notification);
                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    _logger.LogInformation($"Notification created for user {userId}");
                    return (true, notification);
                }

                return (false, null);
            }
            catch (Exception ex)
            {
                _logger.LogError($"Create notification error: {ex.Message}");
                return (false, null);
            }
        }

        public async Task<(bool Success, IEnumerable<Notification>)> CreateNotificationsAsync(List<(int userId, string message, string category, int? entityId, string entityType)> notifications)
        {
            try
            {
                var notificationEntities = notifications.Select(n => new Notification
                {
                    UserId = n.userId,
                    Message = n.message,
                    Category = n.category,
                    EntityId = n.entityId,
                    EntityType = n.entityType,
                    CreatedDate = DateTime.Now,
                    IsRead = false,
                    Status = "Active"
                }).ToList();

                await _unitOfWork.Notifications.AddRangeAsync(notificationEntities);
                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    _logger.LogInformation($"{notificationEntities.Count} notifications created");
                    return (true, notificationEntities);
                }

                return (false, null);
            }
            catch (Exception ex)
            {
                _logger.LogError($"Create notifications error: {ex.Message}");
                return (false, null);
            }
        }

        public async Task<(bool Success, string Message)> MarkAsReadAsync(int notificationId)
        {
            try
            {
                var result = await _unitOfWork.NotificationRepository.MarkAsReadAsync(notificationId);
                if (result)
                {
                    var saved = await _unitOfWork.SaveChangesAsync();
                    return saved ? (true, "Notification marked as read.") : (false, "Failed to mark as read.");
                }

                return (false, "Notification not found.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Mark as read error: {ex.Message}");
                return (false, "An error occurred while marking notification as read.");
            }
        }

        public async Task<(bool Success, string Message)> MarkAllAsReadAsync(int userId)
        {
            try
            {
                var result = await _unitOfWork.NotificationRepository.MarkAllAsReadAsync(userId);
                if (result)
                {
                    var saved = await _unitOfWork.SaveChangesAsync();
                    return saved ? (true, "All notifications marked as read.") : (false, "Failed to mark notifications as read.");
                }

                return (false, "No unread notifications.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Mark all as read error: {ex.Message}");
                return (false, "An error occurred while marking notifications as read.");
            }
        }

        public async Task<(bool Success, string Message)> DeleteNotificationAsync(int notificationId)
        {
            try
            {
                var deleted = await _unitOfWork.Notifications.DeleteAsync(notificationId);
                if (deleted)
                {
                    var saved = await _unitOfWork.SaveChangesAsync();
                    return saved ? (true, "Notification deleted successfully.") : (false, "Failed to delete notification.");
                }

                return (false, "Notification not found.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Delete notification error: {ex.Message}");
                return (false, "An error occurred while deleting notification.");
            }
        }

        public async Task<(bool Success, string Message)> DeleteOldNotificationsAsync(int daysOld)
        {
            try
            {
                var result = await _unitOfWork.NotificationRepository.DeleteOldNotificationsAsync(daysOld);
                if (result)
                {
                    var saved = await _unitOfWork.SaveChangesAsync();
                    return saved ? (true, "Old notifications deleted.") : (false, "Failed to delete old notifications.");
                }

                return (false, "No old notifications found.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Delete old notifications error: {ex.Message}");
                return (false, "An error occurred while deleting old notifications.");
            }
        }

        public async Task<IEnumerable<Notification>> GetNotificationsByCategoryAsync(int userId, string category)
        {
            return await _unitOfWork.NotificationRepository.GetNotificationsByCategoryAsync(userId, category);
        }

        public async Task<string> GetNotificationMessageAsync(string template, Dictionary<string, string> parameters)
        {
            var message = template;

            foreach (var param in parameters)
            {
                message = message.Replace($"{{{param.Key}}}", param.Value);
            }

            return await Task.FromResult(message);
        }
    }
}
