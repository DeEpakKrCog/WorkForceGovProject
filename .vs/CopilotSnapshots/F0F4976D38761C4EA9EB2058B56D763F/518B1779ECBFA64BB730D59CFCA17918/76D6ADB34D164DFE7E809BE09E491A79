using Microsoft.AspNetCore.Mvc;
using Microsoft.AspNetCore.Http;
using Microsoft.EntityFrameworkCore;
using WorkForceGovProject.Data;
using WorkForceGovProject.Models;
using WorkForceGovProject.Services.Interfaces;
using System.Linq;

namespace WorkForceGovProject.Controllers
{
    public class CitizenController : Controller
    {
        private readonly ICitizenService _citizenService;
        private readonly IDocumentService _documentService;
        private readonly IJobService _jobService;
        private readonly IApplicationService _applicationService;
        private readonly IBenefitService _benefitService;
        private readonly INotificationService _notificationService;
        private readonly ILogger<CitizenController> _logger;

        public CitizenController(
            ICitizenService citizenService,
            IDocumentService documentService,
            IJobService jobService,
            IApplicationService applicationService,
            IBenefitService benefitService,
            INotificationService notificationService,
            ILogger<CitizenController> logger)
        {
            _citizenService = citizenService;
            _documentService = documentService;
            _jobService = jobService;
            _applicationService = applicationService;
            _benefitService = benefitService;
            _notificationService = notificationService;
            _logger = logger;
        }

        // Helper method to get logged-in citizen
        private async Task<Citizen> GetLoggedInCitizenAsync()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");
            if (userId == null) return null;
            return await _citizenService.GetCitizenByUserIdAsync(userId.Value);
        }

        // 1. DASHBOARD ACTION
        public async Task<IActionResult> Dashboard()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");
            if (userId == null) return RedirectToAction("Login", "Account");

            var citizen = await _citizenService.GetCitizenByUserIdAsync(userId.Value);

            if (citizen == null)
            {
                var fullName = HttpContext.Session.GetString("UserName") ?? "Citizen User";
                var email = HttpContext.Session.GetString("UserEmail") ?? "";
                var (success, message) = await _citizenService.CreateCitizenProfileAsync(userId.Value, fullName, email);

                if (!success)
                    return RedirectToAction("Login", "Account");

                citizen = await _citizenService.GetCitizenByUserIdAsync(userId.Value);
            }

            // Update stats
            await _citizenService.UpdateDashboardStatsAsync(citizen.Id);
            citizen = await _citizenService.GetCitizenByIdAsync(citizen.Id);

            return View(citizen);
        }

        // 2. PROFILE ACTION
        public async Task<IActionResult> Profile()
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            return View(citizen);
        }

        // 3. UPDATE PROFILE ACTION
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> UpdateProfile(Citizen model)
        {
            var (success, message) = await _citizenService.UpdatePersonalInfoAsync(
                model.Id,
                model.FullName,
                model.DOB,
                model.Gender,
                model.Address,
                model.PhoneNumber);

            if (success)
                TempData["SuccessMessage"] = "Profile updated successfully!";
            else
                TempData["ErrorMessage"] = message;

            return RedirectToAction("Profile");
        }

        // 4. DOCUMENT UPLOAD PAGE
        public async Task<IActionResult> Documents()
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var documents = await _documentService.GetCitizenDocumentsAsync(citizen.Id);
            return View(documents);
        }

        // 5. UPLOAD DOCUMENT POST ACTION
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> UploadDocument(IFormFile file, string documentType)
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var (success, message, document) = await _documentService.UploadDocumentAsync(
                citizen.Id, documentType, file);

            if (success)
                TempData["SuccessMessage"] = message;
            else
                TempData["ErrorMessage"] = message;

            return RedirectToAction("Documents");
        }

        // 6. DELETE DOCUMENT
        [HttpPost]
        public async Task<IActionResult> DeleteDocument(int id)
        {
            var (success, message) = await _documentService.DeleteDocumentAsync(id);

            if (success)
                TempData["SuccessMessage"] = message;
            else
                TempData["ErrorMessage"] = message;

            return RedirectToAction("Documents");
        }

        // 7. JOB SEARCH PAGE
        public async Task<IActionResult> JobSearch(string location = "", string category = "")
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var jobs = await _jobService.SearchJobsAsync(location, category);
            return View(jobs);
        }

        // 8. JOB APPLICATION PAGE
        public async Task<IActionResult> JobApplications()
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var applications = await _applicationService.GetApplicationsByCitizenAsync(citizen.Id);
            return View(applications);
        }

        // 9. APPLY FOR JOB
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> ApplyForJob(int jobId, string coverLetter = "")
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var (success, message, application) = await _applicationService.ApplyForJobAsync(
                citizen.Id, jobId, coverLetter);

            if (success)
                TempData["SuccessMessage"] = message;
            else
                TempData["ErrorMessage"] = message;

            return RedirectToAction("JobApplications");
        }

        // 10. WITHDRAW APPLICATION
        [HttpPost]
        public async Task<IActionResult> WithdrawApplication(int applicationId)
        {
            var (success, message) = await _applicationService.WithdrawApplicationAsync(applicationId);

            if (success)
                TempData["SuccessMessage"] = message;
            else
                TempData["ErrorMessage"] = message;

            return RedirectToAction("JobApplications");
        }

        // 11. BENEFITS PAGE
        public async Task<IActionResult> Benefits()
        {
            var citizen = await GetLoggedInCitizenAsync();
            if (citizen == null) return RedirectToAction("Login", "Account");

            var benefits = await _benefitService.GetCitizenBenefitsAsync(citizen.Id);
            return View(benefits);
        }

        // 12. NOTIFICATIONS PAGE
        public async Task<IActionResult> Notifications()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");
            if (userId == null) return RedirectToAction("Login", "Account");

            var notifications = await _notificationService.GetUserNotificationsAsync(userId.Value);
            return View(notifications);
        }

        // 13. MARK NOTIFICATION AS READ
        [HttpPost]
        public async Task<IActionResult> MarkNotificationAsRead(int notificationId)
        {
            var (success, message) = await _notificationService.MarkAsReadAsync(notificationId);
            return Json(new { success });
        }
    }
}
