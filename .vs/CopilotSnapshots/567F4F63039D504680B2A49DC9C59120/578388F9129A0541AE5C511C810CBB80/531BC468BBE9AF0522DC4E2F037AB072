@model List<UserManagementViewModel>

@{
    ViewData["Title"] = "Manage Users";
}

<!-- Page Header -->
<div class="page-header mb-4">
    <div class="d-flex align-items-center justify-content-between">
        <div>
            <h1 class="page-title">
                <i class="fas fa-users-cog"></i> User Management
            </h1>
            <p class="page-subtitle">Manage and monitor all system users</p>
        </div>
        <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-success btn-lg">
            <i class="fas fa-user-plus me-2"></i> Add New User
        </a>
    </div>
</div>

<!-- Search and Filter Card -->
<div class="card mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="fas fa-filter me-2"></i> Search & Filter
        </h5>
    </div>
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-7">
                <label for="searchTerm" class="form-label">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text" name="searchTerm" id="searchTerm" class="form-control" 
                           placeholder="Search by name, email, or role..." />
                </div>
            </div>
            <div class="col-md-3">
                <label for="status" class="form-label">Status</label>
                <select name="status" id="status" class="form-select">
                    <option value="">All Status</option>
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                </select>
            </div>
            <div class="col-md-2 d-flex align-items-end">
                <button type="submit" class="btn btn-primary w-100">
                    <i class="fas fa-search me-1"></i> Search
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Statistics -->
@if (Model.Any())
{
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h6 class="text-muted mb-2">Total Users</h6>
                    <h3 class="mb-0 text-primary fw-bold">@Model.Count</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h6 class="text-muted mb-2">Active</h6>
                    <h3 class="mb-0 text-success fw-bold">@Model.Count(u => u.Status == "Active")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body py-3">
                    <h6 class="text-muted mb-2">Inactive</h6>
                    <h3 class="mb-0 text-warning fw-bold">@Model.Count(u => u.Status == "Inactive")</h3>
                </div>
            </div>
        </div>
    </div>
}

<!-- Users Table -->
<div class="card">
    <div class="card-header bg-light">
        <h5 class="mb-0">
            <i class="fas fa-list me-2"></i> Users List
        </h5>
    </div>
    <div class="table-responsive">
        @if (Model.Any())
        {
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 25%;">
                            <i class="fas fa-user me-1"></i> Name
                        </th>
                        <th style="width: 25%;">
                            <i class="fas fa-envelope me-1"></i> Email
                        </th>
                        <th style="width: 15%;">
                            <i class="fas fa-tag me-1"></i> Role
                        </th>
                        <th style="width: 15%;">
                            <i class="fas fa-check-circle me-1"></i> Status
                        </th>
                        <th style="width: 15%;">
                            <i class="fas fa-calendar me-1"></i> Date
                        </th>
                        <th style="width: 15%; text-align: center;">
                            <i class="fas fa-cog me-1"></i> Actions
                        </th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar me-3" style="width: 40px; height: 40px; border-radius: 50%; background: linear-gradient(135deg, #0d6efd 0%, #0abde3 100%); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold;">
                                        @user.FullName.Substring(0, 1).ToUpper()
                                    </div>
                                    <strong>@user.FullName</strong>
                                </div>
                            </td>
                            <td>
                                <small class="text-muted">@user.Email</small>
                            </td>
                            <td>
                                <span class="badge bg-info">
                                    <i class="fas fa-briefcase me-1"></i> @user.Role
                                </span>
                            </td>
                            <td>
                                @if (user.Status == "Active")
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check-circle me-1"></i> @user.Status
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-pause-circle me-1"></i> @user.Status
                                    </span>
                                }
                            </td>
                            <td>
                                <small class="text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</small>
                            </td>
                            <td class="text-center">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a href="@Url.Action("EditUser", "Admin", new { id = user.Id })" 
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="fas fa-pen-to-square"></i>
                                    </a>
                                    @if (user.Status == "Active")
                                    {
                                        <form method="post" action="@Url.Action("DeactivateUser", "Admin")" style="display: inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="btn btn-outline-danger" title="Deactivate" 
                                                    onclick="return confirm('Are you sure you want to deactivate this user?');">
                                                <i class="fas fa-ban"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div class="text-center py-5" style="min-height: 300px; display: flex; align-items: center; justify-content: center;">
                <div>
                    <i class="fas fa-inbox me-2" style="font-size: 3rem; opacity: 0.3;"></i>
                    <p class="text-muted mt-3">No users found</p>
                    <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-primary mt-2">
                        <i class="fas fa-user-plus me-1"></i> Create First User
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .avatar {
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    .btn-group-sm .btn {
        padding: 0.4rem 0.6rem;
        font-size: 0.8rem;
    }

    .btn-outline-primary:hover {
        background-color: #0d6efd;
        color: white;
    }

    .btn-outline-danger:hover {
        background-color: #dc3545;
        color: white;
    }
</style>

<!-- Deactivate Modal -->
<div class="modal fade" id="deactivateModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Deactivate User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to deactivate <strong id="userName"></strong>?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deactivateForm" method="post" style="display: inline;">
                    <button type="submit" class="btn btn-danger">Deactivate</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    var deactivateModal = document.getElementById('deactivateModal');
    deactivateModal.addEventListener('show.bs.modal', function (event) {
        var button = event.relatedTarget;
        var userId = button.getAttribute('data-user-id');
        var userName = button.getAttribute('data-user-name');
        
        document.getElementById('userName').textContent = userName;
        document.getElementById('deactivateForm').action = '@Url.Action("DeactivateUser", "Admin")/' + userId;
    });
</script>
