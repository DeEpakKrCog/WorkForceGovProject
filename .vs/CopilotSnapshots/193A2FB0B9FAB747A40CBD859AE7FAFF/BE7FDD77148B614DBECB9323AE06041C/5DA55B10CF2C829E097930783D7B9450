@{
    ViewData["Title"] = "Labor Officer Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Labor Officer Dashboard</h2>
<hr />

<div class="row">

    <!-- Pending Document Verifications -->
    <div class="col-md-3">
        <div class="card p-3">
            <h4>Pending Verifications</h4>
            <p>
                Total Pending:
                <strong>@ViewBag.PendingDocuments</strong>
            </p>

            Document Verification
            View Documents
        </a>
    </div>
</div>

<!-- Compliance Alerts -->
<div class="col-md-3">
    <div class="card p-3">
        <h4>Compliance Alerts</h4>
        <p>
            Violations:
            <strong>@ViewBag.ComplianceAlerts</strong>
        </p>

        Employer Compliance
        View Employers
    </a>
</div>
</div>

<!-- Applications -->
<div class="col-md-3">
    <div class="card p-3">
        <h4>Applications</h4>
        <ul>
            <li>Pending: @ViewBag.PendingApplications</li>
            <li>Approved: @ViewBag.ApprovedApplications</li>
            <li>Rejected: @ViewBag.RejectedApplications</li>
        </ul>

        Job Applications
        Review Applications
    </a>
</div>
</div>

<!-- Notifications -->
<div class="col-md-3">
    <div class="card p-3">
        <h4>Notifications</h4>

        @if (ViewBag.Notifications != null)
        {
            <ul>
                @foreach (var note in ViewBag.Notifications)
                {
                    <li>@note</li>
                }
            </ul>
        }
        else
        {
            <p>No notifications</p>
        }
    </div>
</div>

</div>

<hr />

<div>
    Reports
    Generate Reports
</a>
|
Compliance Audit
Conduct Audit
</a>
</div>