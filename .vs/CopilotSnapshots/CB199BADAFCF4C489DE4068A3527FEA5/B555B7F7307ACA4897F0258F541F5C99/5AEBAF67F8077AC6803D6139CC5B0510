@model List<WorkForceGovProject.Models.CitizenDocument>
@{
    ViewData["Title"] = "Document Verifications";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkForceGov</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- LEFT SIDEBAR NAVIGATION -->
        <div class="sidebar-nav">
            <div class="sidebar-header">
                <a href="#" class="sidebar-logo">
                    <span>🏛️</span>
                    <span>WorkForceGov</span>
                </a>
            </div>

            <div class="sidebar-menu">
                <a asp-action="Dashboard" asp-controller="LaborOfficer">
                    <span class="icon">🏠</span>
                    <span>Dashboard</span>
                </a>
                <a href="#" class="active">
                    <span class="icon">📋</span>
                    <span>Pending Documents</span>
                </a>
                <a asp-action="Applications" asp-controller="LaborOfficer">
                    <span class="icon">📝</span>
                    <span>Applications</span>
                </a>
                <a asp-action="Compliance" asp-controller="LaborOfficer">
                    <span class="icon">⚖️</span>
                    <span>Compliance</span>
                </a>
                <a asp-action="Employers" asp-controller="LaborOfficer">
                    <span class="icon">🏢</span>
                    <span>Employers</span>
                </a>
                <a asp-action="Reports" asp-controller="LaborOfficer">
                    <span class="icon">📊</span>
                    <span>Reports</span>
                </a>
                <a asp-action="Audits" asp-controller="LaborOfficer">
                    <span class="icon">🔍</span>
                    <span>Audit Logs</span>
                </a>
                <a href="#">
                    <span class="icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <a asp-action="Logout" asp-controller="Account" style="color: #ef4444;">
                    <span class="icon">🚪</span>
                    <span>Sign Out</span>
                </a>
            </div>
        </div>

        <!-- MAIN CONTENT AREA -->
        <div class="main-content">
            <!-- Page Header -->
            <div class="dashboard-header">
                <div class="dashboard-title">
                    <div class="dashboard-subtitle">Document Verification Management</div>
                    <h1>Pending Document Verifications</h1>
                </div>
                <button class="btn-dashboard-primary">
                    <span>📊</span> Export List
                </button>
            </div>

            <!-- Stats Summary -->
            <div class="stats-grid mb-4">
                <div class="stat-card">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-label">Total Pending</div>
                    <div class="stat-value" style="color: #f59e0b;">@Model.Count</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">📄</div>
                    <div class="stat-label">ID Proofs</div>
                    <div class="stat-value">@Model.Count(d => d.DocType == "IDProof")</div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🎓</div>
                    <div class="stat-label">Qualifications</div>
                    <div class="stat-value">@Model.Count(d => d.DocType == "Qualification")</div>
                </div>
            </div>

            <!-- Documents Table -->
            <div class="activity-card">
                <h3 class="mb-4">Documents Awaiting Verification</h3>

                @if (Model == null || !Model.Any())
                {
                    <div class="alert alert-info">
                        <strong>No pending documents!</strong> All documents have been verified.
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead style="background: #f1f5f9;">
                                <tr>
                                    <th>Document ID</th>
                                    <th>Citizen Name</th>
                                    <th>Document Type</th>
                                    <th>Upload Date</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in Model)
                                {
                                    <tr>
                                        <td><strong>#@doc.DocumentID</strong></td>
                                        <td>@doc.Citizen?.FullName</td>
                                        <td>
                                            <span class="badge" style="background: #3b82f6; color: white; padding: 6px 12px; border-radius: 6px;">
                                                @doc.DocType
                                            </span>
                                        </td>
                                        <td>@doc.UploadedDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="badge" style="background: #f59e0b; color: white; padding: 6px 12px; border-radius: 6px;">
                                                @doc.VerificationStatus
                                            </span>
                                        </td>
                                        <td>
                                            <div style="display: flex; gap: 8px;">
                                                <form asp-action="ApproveDocument" asp-controller="LaborOfficer" method="post" style="display: inline;">
                                                    <input type="hidden" name="documentId" value="@doc.DocumentID" />
                                                    <button type="submit" class="btn btn-sm" style="background: #10b981; color: white; border: none; padding: 6px 16px; border-radius: 6px; font-weight: 600;">
                                                        ✅ Approve
                                                    </button>
                                                </form>
                                                <button type="button" class="btn btn-sm" style="background: #ef4444; color: white; border: none; padding: 6px 16px; border-radius: 6px; font-weight: 600;" 
                                                        onclick="showRejectModal(@doc.DocumentID, '@doc.Citizen?.FullName', '@doc.DocType')">
                                                    ❌ Reject
                                                </button>
                                                @if (!string.IsNullOrEmpty(doc.FileURI))
                                                {
                                                    <a href="@doc.FileURI" target="_blank" class="btn btn-sm" style="background: #3b82f6; color: white; border: none; padding: 6px 16px; border-radius: 6px; font-weight: 600;">
                                                        👁️ View
                                                    </a>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Reject Modal -->
    <div class="modal fade" id="rejectModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reject Document</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <form asp-action="RejectDocument" asp-controller="LaborOfficer" method="post">
                    <div class="modal-body">
                        <input type="hidden" name="documentId" id="rejectDocId" />
                        <p><strong>Citizen:</strong> <span id="rejectCitizenName"></span></p>
                        <p><strong>Document Type:</strong> <span id="rejectDocType"></span></p>
                        <div class="mb-3">
                            <label class="form-label">Rejection Reason</label>
                            <textarea name="notes" class="form-control" rows="3" placeholder="Enter reason for rejection..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-danger">Reject Document</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function showRejectModal(docId, citizenName, docType) {
            document.getElementById('rejectDocId').value = docId;
            document.getElementById('rejectCitizenName').textContent = citizenName;
            document.getElementById('rejectDocType').textContent = docType;
            new bootstrap.Modal(document.getElementById('rejectModal')).show();
        }
    </script>
</body>
</html>