            return View(program);
        }

        // POST: ProgramManager/DeleteProgram/5
        [HttpPost, ActionName("DeleteProgram")]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> DeleteProgramConfirmed(int id)
        {
            var program = await _unitOfWork.EmploymentPrograms.GetByIdAsync(id);
            if (program != null)
            {
                _unitOfWork.EmploymentPrograms.Remove(program);
                await _unitOfWork.SaveChangesAsync();
                TempData["SuccessMessage"] = "Program deleted successfully!";
            }

            return RedirectToAction("ProgramManagement");
        }

        // GET: ProgramManager/BudgetMonitoring
        public async Task<IActionResult> BudgetMonitoring()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            var programs = await _unitOfWork.EmploymentPrograms.GetProgramsWithBenefitsAsync();
            var programsList = programs.ToList();

            // Calculate budget statistics for each program
            var budgetData = programsList.Select(p => new
            {
                Program = p,
                TotalSpent = p.Benefits?.Sum(b => b.Amount) ?? 0,
                RemainingBudget = p.Budget - (p.Benefits?.Sum(b => b.Amount) ?? 0),
                UtilizationPercentage = p.Budget > 0 ? ((p.Benefits?.Sum(b => b.Amount) ?? 0) / p.Budget * 100) : 0,
                BenefitsCount = p.Benefits?.Count ?? 0
            }).ToList();

            ViewBag.BudgetData = budgetData;
            ViewBag.TotalBudget = await _unitOfWork.EmploymentPrograms.GetTotalBudgetAsync();
            ViewBag.TotalSpent = programsList.Sum(p => p.Benefits?.Sum(b => b.Amount) ?? 0);
            ViewBag.TotalRemaining = ViewBag.TotalBudget - ViewBag.TotalSpent;
            ViewBag.OverallUtilization = ViewBag.TotalBudget > 0 ? (ViewBag.TotalSpent / ViewBag.TotalBudget * 100) : 0;

            return View(programsList);
        }

        // GET: ProgramManager/PerformanceTracking
        public async Task<IActionResult> PerformanceTracking()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            var programs = await _unitOfWork.EmploymentPrograms.GetProgramWithAllDetailsAsync(0);
            var allPrograms = await _unitOfWork.EmploymentPrograms.GetProgramsWithBenefitsAsync();

            // Calculate beneficiary statistics
            var allBenefits = await _unitOfWork.Benefits.GetBenefitsWithDetailsAsync();
            var benefitsList = allBenefits.ToList();

            ViewBag.TotalBeneficiaries = benefitsList.Select(b => b.CitizenID).Distinct().Count();
            ViewBag.TotalBenefitsDistributed = benefitsList.Count;
            ViewBag.TotalAmountPaid = benefitsList.Sum(b => b.Amount);
            ViewBag.RecentBeneficiaries = benefitsList
                .OrderByDescending(b => b.Date)
                .Take(5)
                .ToList();

            return View(allPrograms);
        }

