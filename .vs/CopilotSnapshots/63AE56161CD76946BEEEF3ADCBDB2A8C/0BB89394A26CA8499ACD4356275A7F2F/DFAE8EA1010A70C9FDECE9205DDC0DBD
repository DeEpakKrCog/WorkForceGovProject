        private readonly IUnitOfWork _unitOfWork;

        public ProgramManagerController(IUnitOfWork unitOfWork)
        {
            _unitOfWork = unitOfWork;
        }

        // GET: ProgramManager/Dashboard
        public async Task<IActionResult> Dashboard()
        {
            // Simulate logged-in user for testing
            HttpContext.Session.SetInt32("UserId", 1);
            HttpContext.Session.SetString("UserName", "Program Manager");

            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            // Get summary statistics for dashboard using repositories
            var totalPrograms = await _unitOfWork.EmploymentPrograms.CountAsync();
            var activePrograms = await _unitOfWork.EmploymentPrograms.CountAsync(p => p.Status == "Active");
            var totalBudget = await _unitOfWork.EmploymentPrograms.GetTotalBudgetAsync();
            var activeTrainings = await _unitOfWork.Trainings.CountAsync(t => t.Status == "Active");
            var totalBenefits = await _unitOfWork.Benefits.GetTotalAmountDistributedAsync();

            ViewBag.TotalPrograms = totalPrograms;
            ViewBag.ActivePrograms = activePrograms;
            ViewBag.TotalBudget = totalBudget;
            ViewBag.ActiveTrainings = activeTrainings;
            ViewBag.TotalBenefits = totalBenefits;

            return View();
        }

        // GET: ProgramManager/ProgramManagement
        public async Task<IActionResult> ProgramManagement()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            var programs = await _unitOfWork.EmploymentPrograms.GetAllAsync();
            return View(programs);
        }

        // GET: ProgramManager/CreateProgram
        public IActionResult CreateProgram()
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            return View();
        }

        // POST: ProgramManager/CreateProgram
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> CreateProgram(EmploymentProgram program)
        {
            if (ModelState.IsValid)
            {
                await _unitOfWork.EmploymentPrograms.AddAsync(program);
                await _unitOfWork.SaveChangesAsync();
                TempData["SuccessMessage"] = "Program created successfully!";
                return RedirectToAction("ProgramManagement");
            }

            return View(program);
        }

        // GET: ProgramManager/EditProgram/5
        public async Task<IActionResult> EditProgram(int id)
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            var program = await _unitOfWork.EmploymentPrograms.GetByIdAsync(id);
            if (program == null)
            {
                return NotFound();
            }

            return View(program);
        }

        // POST: ProgramManager/EditProgram/5
        [HttpPost]
        [ValidateAntiForgeryToken]
        public async Task<IActionResult> EditProgram(int id, EmploymentProgram program)
        {
            if (id != program.ProgramID)
            {
                return NotFound();
            }

            if (ModelState.IsValid)
            {
                try
                {
                    _unitOfWork.EmploymentPrograms.Update(program);
                    await _unitOfWork.SaveChangesAsync();
                    TempData["SuccessMessage"] = "Program updated successfully!";
                }
                catch (DbUpdateConcurrencyException)
                {
                    if (!await _unitOfWork.EmploymentPrograms.AnyAsync(e => e.ProgramID == id))
                    {
                        return NotFound();
                    }
                    throw;
                }
                return RedirectToAction("ProgramManagement");
            }

            return View(program);
        }

        // GET: ProgramManager/DeleteProgram/5
        public async Task<IActionResult> DeleteProgram(int id)
        {
            int? userId = HttpContext.Session.GetInt32("UserId");

            if (userId == null)
            {
                return RedirectToAction("Login", "Account");
            }

            var program = await _unitOfWork.EmploymentPrograms.GetByIdAsync(id);
            if (program == null)
            {
