                {
                    UserId = n.userId,
                    Message = n.message,
                    Category = n.category,
                    EntityId = n.entityId,
                    EntityType = n.entityType,
                    CreatedDate = DateTime.Now,
                    IsRead = false,
                    Status = "Active"
                }).ToList();

