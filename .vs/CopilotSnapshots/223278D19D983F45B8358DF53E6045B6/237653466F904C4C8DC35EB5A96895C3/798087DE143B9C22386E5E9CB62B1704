using Microsoft.EntityFrameworkCore;
using WorkForceGovProject.Data;
using WorkForceGovProject.Models;
using WorkForceGovProject.Interfaces;

namespace WorkForceGovProject.Repositories.Implementations
{
    /// <summary>
    /// Citizen Repository Implementation
    /// Handles citizen profile data operations
    /// </summary>
    public class CitizenRepository : Repository<Citizen>, ICitizenRepository
    {
        public CitizenRepository(ApplicationDbContext context) : base(context) { }

        public async Task<Citizen> GetCitizenByUserIdAsync(int userId)
        {
            return await _dbSet
                .Include(c => c.User)
                .FirstOrDefaultAsync(c => c.UserId == userId);
        }

        public async Task<Citizen> GetCitizenWithDocumentsAsync(int citizenId)
        {
            return await _dbSet
                .Include(c => c.Documents)
                .FirstOrDefaultAsync(c => c.Id == citizenId);
        }

        public async Task<Citizen> GetCitizenWithApplicationsAsync(int citizenId)
        {
            return await _dbSet
                .Include(c => c.Applications)
                    .ThenInclude(a => a.JobOpening)
                .FirstOrDefaultAsync(c => c.Id == citizenId);
        }

        public async Task<Citizen> GetCitizenWithBenefitsAsync(int citizenId)
        {
            return await _dbSet
                .Include(c => c.Benefits)
                    .ThenInclude(b => b.Program)
                .FirstOrDefaultAsync(c => c.Id == citizenId);
        }

        public async Task<IEnumerable<Citizen>> GetPendingDocumentVerificationAsync()
        {
            return await _dbSet
                .Include(c => c.Documents)
                .Where(c => c.DocumentStatus == "Pending")
                .ToListAsync();
        }
    }
}
