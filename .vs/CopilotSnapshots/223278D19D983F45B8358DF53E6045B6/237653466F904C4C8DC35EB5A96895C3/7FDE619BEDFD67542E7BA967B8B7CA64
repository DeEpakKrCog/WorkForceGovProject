using WorkForceGovProject.Models;

namespace WorkForceGovProject.Interfaces
{
    /// <summary>
    /// Benefit Service Interface
    /// Defines operations for benefit management
    /// </summary>
    public interface IBenefitService
    {
        Task<Benefit> GetBenefitByIdAsync(int benefitId);
        Task<IEnumerable<Benefit>> GetBenefitsByCitizenAsync(int citizenId);
