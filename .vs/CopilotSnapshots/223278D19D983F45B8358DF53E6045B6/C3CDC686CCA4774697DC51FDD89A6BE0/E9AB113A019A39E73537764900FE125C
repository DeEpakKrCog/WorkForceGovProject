using WorkForceGovProject.Models;
using WorkForceGovProject.Repositories;

namespace WorkForceGovProject.Services
{
    /// <summary>
    /// Benefit Service Implementation
    /// Handles benefit and program operations
    /// </summary>
    public class BenefitService : IBenefitService
    {
        private readonly IUnitOfWork _unitOfWork;
        private readonly INotificationService _notificationService;
        private readonly ILogger<BenefitService> _logger;

        public BenefitService(IUnitOfWork unitOfWork, INotificationService notificationService, ILogger<BenefitService> logger)
        {
            _unitOfWork = unitOfWork;
            _notificationService = notificationService;
            _logger = logger;
        }

        public async Task<Benefit> GetBenefitByIdAsync(int id)
        {
            return await _unitOfWork.Benefits.GetByIdAsync(id);
        }

        public async Task<IEnumerable<Benefit>> GetCitizenBenefitsAsync(int citizenId)
        {
            return await _unitOfWork.Benefits.FindAsync(b => b.CitizenId == citizenId);
        }

        public async Task<IEnumerable<Benefit>> GetActiveBenefitsAsync(int citizenId)
        {
            return await _unitOfWork.Benefits.FindAsync(b => b.CitizenId == citizenId && b.Status == "Active");
        }

        public async Task<(bool Success, string Message, Benefit Benefit)> AllocateBenefitAsync(int citizenId, int programId, string benefitType, decimal amount, string description = "")
        {
            try
            {
                var citizen = await _unitOfWork.Citizens.GetByIdAsync(citizenId);
                if (citizen == null)
                    return (false, "Citizen not found.", null);

                var program = await _unitOfWork.EmploymentPrograms.GetByIdAsync(programId);
                if (program == null)
                    return (false, "Program not found.", null);

                var benefit = new Benefit
                {
                    CitizenId = citizenId,
                    ProgramId = programId,
                    BenefitType = benefitType,
                    Amount = amount,
                    BenefitDate = DateTime.Now,
                    Status = "Active",
                    Description = description
                };

                await _unitOfWork.Benefits.AddAsync(benefit);

                // Update citizen account balance
                citizen.AccountBalance += amount;
                await _unitOfWork.Citizens.UpdateAsync(citizen);

                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    // Create notification
                    await _notificationService.CreateNotificationAsync(
                        citizen.UserId,
                        $"You have been allocated ₹{amount} under {program.ProgramName}",
                        "BenefitApproval",
                        benefit.Id,
                        "Benefit"
                    );

                    _logger.LogInformation($"Benefit allocated to citizen {citizenId}");
                    return (true, "Benefit allocated successfully.", benefit);
                }

                return (false, "Failed to allocate benefit.", null);
            }
            catch (Exception ex)
            {
                _logger.LogError($"Allocate benefit error: {ex.Message}");
                return (false, "An error occurred while allocating benefit.", null);
            }
        }

        public async Task<(bool Success, string Message)> CompleteBenefitAsync(int benefitId)
        {
            try
            {
                var benefit = await GetBenefitByIdAsync(benefitId);
                if (benefit == null)
                    return (false, "Benefit not found.");

                benefit.Status = "Completed";
                await _unitOfWork.Benefits.UpdateAsync(benefit);
                var saved = await _unitOfWork.SaveChangesAsync();

                return saved ? (true, "Benefit marked as completed.") : (false, "Failed to complete benefit.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Complete benefit error: {ex.Message}");
                return (false, "An error occurred while completing benefit.");
            }
        }

        public async Task<(bool Success, string Message)> WithdrawBenefitAsync(int benefitId)
        {
            try
            {
                var benefit = await GetBenefitByIdAsync(benefitId);
                if (benefit == null)
                    return (false, "Benefit not found.");

                var citizen = await _unitOfWork.Citizens.GetByIdAsync(benefit.CitizenId);
                if (citizen != null)
                {
                    citizen.AccountBalance -= benefit.Amount;
                    await _unitOfWork.Citizens.UpdateAsync(citizen);
                }

                benefit.Status = "Withdrawn";
                await _unitOfWork.Benefits.UpdateAsync(benefit);
                var saved = await _unitOfWork.SaveChangesAsync();

                return saved ? (true, "Benefit withdrawn successfully.") : (false, "Failed to withdraw benefit.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Withdraw benefit error: {ex.Message}");
                return (false, "An error occurred while withdrawing benefit.");
            }
        }

        public async Task<EmploymentProgram> GetProgramByIdAsync(int id)
        {
            return await _unitOfWork.EmploymentPrograms.GetByIdAsync(id);
        }

        public async Task<IEnumerable<EmploymentProgram>> GetAllProgramsAsync()
        {
            return await _unitOfWork.EmploymentPrograms.GetAllAsync();
        }

        public async Task<IEnumerable<EmploymentProgram>> GetActiveProgramsAsync()
        {
            return await _unitOfWork.EmploymentPrograms.FindAsync(p => p.Status == "Active");
        }

        public async Task<(bool Success, string Message, EmploymentProgram Program)> CreateProgramAsync(EmploymentProgram program)
        {
            try
            {
                if (program == null || string.IsNullOrEmpty(program.ProgramName))
                    return (false, "Invalid program information.", null);

                program.Status = "Active";
                program.StartDate = DateTime.Now;

                await _unitOfWork.EmploymentPrograms.AddAsync(program);
                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    _logger.LogInformation($"Employment program created: {program.ProgramName}");
                    return (true, "Program created successfully.", program);
                }

                return (false, "Failed to create program.", null);
            }
            catch (Exception ex)
            {
                _logger.LogError($"Create program error: {ex.Message}");
                return (false, "An error occurred while creating program.", null);
            }
        }

        public async Task<(bool Success, string Message)> UpdateProgramAsync(EmploymentProgram program)
        {
            try
            {
                await _unitOfWork.EmploymentPrograms.UpdateAsync(program);
                var saved = await _unitOfWork.SaveChangesAsync();
                return saved ? (true, "Program updated successfully.") : (false, "Failed to update program.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Update program error: {ex.Message}");
                return (false, "An error occurred while updating program.");
            }
        }

        public async Task<decimal> GetTotalBenefitAmountAsync(int citizenId)
        {
            var benefits = await GetCitizenBenefitsAsync(citizenId);
            return benefits.Sum(b => b.Amount);
        }

        public async Task<int> GetActiveBenefitCountAsync(int citizenId)
        {
            return await _unitOfWork.Benefits.CountAsync(b => b.CitizenId == citizenId && b.Status == "Active");
        }

        public async Task<IEnumerable<Benefit>> GetBenefitsByTypeAsync(int citizenId, string benefitType)
        {
            return await _unitOfWork.Benefits.FindAsync(b => b.CitizenId == citizenId && b.BenefitType == benefitType);
        }
    }
}
