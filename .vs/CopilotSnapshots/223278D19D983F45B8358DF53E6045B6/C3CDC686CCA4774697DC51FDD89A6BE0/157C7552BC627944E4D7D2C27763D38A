using WorkForceGovProject.Models;
using WorkForceGovProject.Repositories;

namespace WorkForceGovProject.Services
{
    /// <summary>
    /// Application Service Implementation
    /// Handles job application operations
    /// </summary>
    public class ApplicationService : IApplicationService
    {
        private readonly IUnitOfWork _unitOfWork;
        private readonly INotificationService _notificationService;
        private readonly ILogger<ApplicationService> _logger;

        public ApplicationService(IUnitOfWork unitOfWork, INotificationService notificationService, ILogger<ApplicationService> logger)
        {
            _unitOfWork = unitOfWork;
            _notificationService = notificationService;
            _logger = logger;
        }

        public async Task<Application> GetApplicationByIdAsync(int id)
        {
            return await _unitOfWork.Applications.GetByIdAsync(id);
        }

        public async Task<IEnumerable<Application>> GetApplicationsByCitizenAsync(int citizenId)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationsByCitizenAsync(citizenId);
        }

        public async Task<IEnumerable<Application>> GetApplicationsByJobAsync(int jobId)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationsByJobAsync(jobId);
        }

        public async Task<(bool Success, string Message, Application Application)> ApplyForJobAsync(int citizenId, int jobId, string coverLetter = "")
        {
            try
            {
                // Check if already applied
                var existing = await _unitOfWork.ApplicationRepository.GetCitizenJobApplicationAsync(citizenId, jobId);
                if (existing != null)
                    return (false, "You have already applied for this job.", null);

                var job = await _unitOfWork.JobOpenings.GetByIdAsync(jobId);
                if (job == null || job.Status != "Open")
                    return (false, "This job is not available for application.", null);

                var application = new Application
                {
                    CitizenId = citizenId,
                    JobOpeningId = jobId,
                    SubmittedDate = DateTime.Now,
                    Status = "Pending",
                    CoverLetter = coverLetter
                };

                await _unitOfWork.Applications.AddAsync(application);

                // Update job application count
                job.TotalApplications++;
                await _unitOfWork.JobOpenings.UpdateAsync(job);

                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    // Create notification
                    var citizen = await _unitOfWork.Citizens.GetByIdAsync(citizenId);
                    await _notificationService.CreateNotificationAsync(
                        citizen.UserId,
                        $"Your application for '{job.JobTitle}' has been submitted successfully.",
                        "JobApplication",
                        application.Id,
                        "Application"
                    );

                    _logger.LogInformation($"Application submitted for citizen {citizenId} to job {jobId}");
                    return (true, "Application submitted successfully.", application);
                }

                return (false, "Failed to submit application.", null);
            }
            catch (Exception ex)
            {
                _logger.LogError($"Apply for job error: {ex.Message}");
                return (false, "An error occurred while applying for job.", null);
            }
        }

        public async Task<(bool Success, string Message)> WithdrawApplicationAsync(int applicationId)
        {
            try
            {
                var application = await GetApplicationByIdAsync(applicationId);
                if (application == null)
                    return (false, "Application not found.");

                if (application.Status != "Pending")
                    return (false, "Only pending applications can be withdrawn.");

                application.Status = "Withdrawn";
                await _unitOfWork.Applications.UpdateAsync(application);
                var saved = await _unitOfWork.SaveChangesAsync();

                return saved ? (true, "Application withdrawn successfully.") : (false, "Failed to withdraw application.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Withdraw application error: {ex.Message}");
                return (false, "An error occurred while withdrawing application.");
            }
        }

        public async Task<Application> GetApplicationWithDetailsAsync(int applicationId)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationWithDetailsAsync(applicationId);
        }

        public async Task<bool> HasAppliedAsync(int citizenId, int jobId)
        {
            var application = await _unitOfWork.ApplicationRepository.GetCitizenJobApplicationAsync(citizenId, jobId);
            return application != null;
        }

        public async Task<IEnumerable<Application>> GetApplicationsByStatusAsync(string status)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationsByStatusAsync(status);
        }

        public async Task<(bool Success, string Message)> ApproveApplicationAsync(int applicationId, string notes = "")
        {
            try
            {
                var application = await GetApplicationByIdAsync(applicationId);
                if (application == null)
                    return (false, "Application not found.");

                application.Status = "Approved";
                application.ReviewedDate = DateTime.Now;
                application.ReviewNotes = notes;

                await _unitOfWork.Applications.UpdateAsync(application);
                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    _logger.LogInformation($"Application {applicationId} approved.");
                    return (true, "Application approved successfully.");
                }

                return (false, "Failed to approve application.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Approve application error: {ex.Message}");
                return (false, "An error occurred while approving application.");
            }
        }

        public async Task<(bool Success, string Message)> RejectApplicationAsync(int applicationId, string notes = "")
        {
            try
            {
                var application = await GetApplicationByIdAsync(applicationId);
                if (application == null)
                    return (false, "Application not found.");

                application.Status = "Rejected";
                application.ReviewedDate = DateTime.Now;
                application.ReviewNotes = notes;

                await _unitOfWork.Applications.UpdateAsync(application);
                var saved = await _unitOfWork.SaveChangesAsync();

                if (saved)
                {
                    _logger.LogInformation($"Application {applicationId} rejected.");
                    return (true, "Application rejected successfully.");
                }

                return (false, "Failed to reject application.");
            }
            catch (Exception ex)
            {
                _logger.LogError($"Reject application error: {ex.Message}");
                return (false, "An error occurred while rejecting application.");
            }
        }

        public async Task<int> GetApplicationCountByCitizenAsync(int citizenId)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationCountByCitizenAsync(citizenId);
        }

        public async Task<int> GetPendingApplicationCountAsync(int citizenId)
        {
            return await _unitOfWork.ApplicationRepository.CountAsync(a => a.CitizenId == citizenId && a.Status == "Pending");
        }

        public async Task<int> GetApplicationCountByJobAsync(int jobId)
        {
            return await _unitOfWork.ApplicationRepository.GetApplicationCountByJobAsync(jobId);
        }
    }
}
