@model WorkForceGovProject.Models.User
@{
    ViewData["Title"] = "Register";
}

<section class="container d-flex align-items-center justify-content-center py-5" style="min-height: 80vh;">
    <div class="card shadow border-0 p-4" style="max-width: 450px; width: 100%; border-top: 5px solid #00274d !important;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-dark">Create Account</h2>
            <p class="text-muted small">Join the National Workforce Platform</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <div class="mb-3">
                <label asp-for="FullName" class="form-label fw-semibold">Full Name</label>
                <input asp-for="FullName" class="form-control" placeholder="John Doe" required />
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold">Email</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="john@gov.com" required />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold">Password</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="••••••••" required />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Role" class="form-label fw-semibold">Account Type</label>
                <select asp-for="Role" class="form-select" required>
                    <option value="">-- Choose Role --</option>
                    <option value="Citizen">Citizen (Job Seeker)</option>
                    <option value="Employer">Employer (Hiring)</option>
                    <option value="LaborOfficer">Labor Officer</option>
                </select>
                <span asp-validation-for="Role" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold mb-3 shadow-sm">Register Now</button>
            
            <div class="text-center small">
                <span class="text-muted">Already have an account?</span>
                <a asp-action="Login" class="text-decoration-none fw-bold text-primary">Sign In</a>
            </div>
        </form>
    </div>
</section>