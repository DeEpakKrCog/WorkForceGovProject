        html { scroll-behavior: smooth; }

        /* User Initial Circle Styling */
        .user-initial-circle {
            width: 42px;
            height: 42px;
            background: #3b82f6;
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.1rem;
            text-decoration: none;
            transition: 0.3s;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
        }
        .user-initial-circle:hover {
            background: #2563eb;
            color: white;
            transform: scale(1.05);
        }
    </style>

    @await RenderSectionAsync("Styles", required: false)
