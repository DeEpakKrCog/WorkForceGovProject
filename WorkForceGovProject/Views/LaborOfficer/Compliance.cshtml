@{
    ViewData["Title"] = "Compliance Management";
}

<div class="container mt-4">
    <h2>Compliance Management</h2>
    
    <div class="row mt-4">
        <div class="col-md-4">
            <div class="card text-white bg-warning mb-3">
                <div class="card-body">
                    <h5 class="card-title">Compliance Violations</h5>
                    <h2>4</h2>
                    <p class="card-text">Active violations requiring attention</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-success mb-3">
                <div class="card-body">
                    <h5 class="card-title">Compliant Employers</h5>
                    <h2>87</h2>
                    <p class="card-text">Employers in good standing</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-white bg-info mb-3">
                <div class="card-body">
                    <h5 class="card-title">Pending Reviews</h5>
                    <h2>12</h2>
                    <p class="card-text">Compliance checks scheduled</p>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Recent Compliance Records</h5>
                </div>
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Employer</th>
                                <th>Violation Type</th>
                                <th>Date Reported</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>ABC Corporation</td>
                                <td>Safety Violation</td>
                                <td>@DateTime.Now.AddDays(-2).ToShortDateString()</td>
                                <td><span class="badge bg-warning">Under Review</span></td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Review</button>
                                </td>
                            </tr>
                            <tr>
                                <td>XYZ Industries</td>
                                <td>Documentation Missing</td>
                                <td>@DateTime.Now.AddDays(-5).ToShortDateString()</td>
                                <td><span class="badge bg-danger">Open</span></td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Review</button>
                                </td>
                            </tr>
                            <tr>
                                <td>Tech Solutions Ltd</td>
                                <td>Late Payment</td>
                                <td>@DateTime.Now.AddDays(-1).ToShortDateString()</td>
                                <td><span class="badge bg-warning">Under Review</span></td>
                                <td>
                                    <button class="btn btn-sm btn-primary">Review</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>