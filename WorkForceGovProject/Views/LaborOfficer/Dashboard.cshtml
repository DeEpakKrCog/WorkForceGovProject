@{
    ViewData["Title"] = "Labor Officer Dashboard";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkForceGov</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="dashboard-wrapper">
        <!-- LEFT SIDEBAR NAVIGATION -->
        <div class="sidebar-nav">
            <div class="sidebar-header">
                <a href="#" class="sidebar-logo">
                    <span>🏛️</span>
                    <span>WorkForceGov</span>
                </a>
            </div>

            <div class="sidebar-menu">
                <a href="#" class="active">
                    <span class="icon">🏠</span>
                    <span>Dashboard</span>
                </a>
                <a asp-action="DocumentVerifications" asp-controller="LaborOfficer">
                    <span class="icon">📋</span>
                    <span>Document Verifications</span>
                </a>
                <a asp-action="Applications" asp-controller="LaborOfficer">
                    <span class="icon">📝</span>
                    <span>Applications</span>
                </a>
                <a asp-action="Compliance" asp-controller="LaborOfficer">
                    <span class="icon">⚖️</span>
                    <span>Compliance</span>
                </a>
                <a asp-action="Employers" asp-controller="LaborOfficer">
                    <span class="icon">🏢</span>
                    <span>Employers</span>
                </a>
                <a asp-action="Reports" asp-controller="LaborOfficer">
                    <span class="icon">📊</span>
                    <span>Reports</span>
                </a>
                <a asp-action="Audits" asp-controller="LaborOfficer">
                    <span class="icon">🔍</span>
                    <span>Audit Logs</span>
                </a>
                <a href="#">
                    <span class="icon">⚙️</span>
                    <span>Settings</span>
                </a>
            </div>

            <div class="sidebar-footer">
                <a asp-action="Logout" asp-controller="Account" style="color: #ef4444;">
                    <span class="icon">🚪</span>
                    <span>Sign Out</span>
                </a>
            </div>
        </div>

        <!-- MAIN CONTENT AREA -->
        <div class="main-content">
            <!-- Dashboard Header -->
            <div class="dashboard-header">
                <div class="dashboard-title">
                    <div class="dashboard-subtitle">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
                    <h1>Labor Officer Control Panel</h1>
                </div>
                <button class="btn-dashboard-primary">
                    <span>📊</span> Generate Report
                </button>
            </div>

            <!-- Stats Cards -->
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">⏳</div>
                    <div class="stat-label">Document Verifiactions</div>
                    <div class="stat-value" style="color: #f59e0b;">@ViewBag.PendingDocuments</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">⚠️</div>
                    <div class="stat-label">Compliance Alerts</div>
                    <div class="stat-value" style="color: #ef4444;">@ViewBag.ComplianceAlerts</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">📝</div>
                    <div class="stat-label">Pending Applications</div>
                    <div class="stat-value">@ViewBag.PendingApplications</div>
                </div>

                <div class="stat-card">
                    <div class="stat-icon">✅</div>
                    <div class="stat-label">Approved Today</div>
                    <div class="stat-value" style="color: #10b981;">@ViewBag.ApprovedApplications</div>
                </div>
            </div>

            <!-- Application Stats -->
            <div class="row mb-4">
                <div class="col-md-8">
                    <div class="activity-card">
                        <h3>Recent Notifications</h3>
                        
                        @if (ViewBag.Notifications != null)
                        {
                            @foreach (var notification in ViewBag.Notifications)
                            {
                                <div class="activity-item">
                                    <span class="status-dot warning"></span>
                                    <span class="activity-text">@notification</span>
                                </div>
                            }
                        }

                        <div class="activity-item">
                            <span class="status-dot success"></span>
                            <span class="activity-text">@ViewBag.ApprovedApplications applications approved today</span>
                        </div>

                        <div class="activity-item">
                            <span class="status-dot error"></span>
                            <span class="activity-text">@ViewBag.RejectedApplications applications rejected</span>
                        </div>

                        <div class="activity-item">
                            <span class="status-dot"></span>
                            <span class="activity-text">System compliance check completed successfully</span>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="activity-card">
                        <h3>Quick Actions</h3>
                        <div style="display: flex; flex-direction: column; gap: 12px;">
                            <a asp-action="PendingDocuments" asp-controller="LaborOfficer" class="btn-dashboard-primary" style="text-align: center; text-decoration: none;">
                                Review Documents
                            </a>
                            <a asp-action="Applications" asp-controller="LaborOfficer" class="btn-dashboard-primary" style="text-align: center; text-decoration: none; background: linear-gradient(135deg, #10b981 0%, #059669 100%); box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);">
                                Process Applications
                            </a>
                            <a asp-action="Compliance" asp-controller="LaborOfficer" class="btn-dashboard-primary" style="text-align: center; text-decoration: none; background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); box-shadow: 0 4px 12px rgba(245, 158, 11, 0.3);">
                                View Compliance
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
