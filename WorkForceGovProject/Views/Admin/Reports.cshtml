@model List<ReportListViewModel>

@{
    ViewData["Title"] = "Reports";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-file-alt"></i> System Reports</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("GenerateReport", "Admin")" class="btn btn-success">
                <i class="fas fa-plus"></i> Generate Report
            </a>
        </div>
    </div>

    <!-- Filter -->
    <div class="card mb-4">
        <div class="card-body">
            <form method="get" class="row g-3">
                <div class="col-md-9">
                    <select name="reportType" class="form-select">
                        <option value="">All Report Types</option>
                        <option value="Employment">Employment</option>
                        <option value="Compliance">Compliance</option>
                        <option value="Participation">Participation</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Reports Table -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Report Name</th>
                        <th>Type</th>
                        <th>Generated Date</th>
                        <th>Generated By</th>
                        <th>Period</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        @foreach (var report in Model)
                        {
                            <tr>
                                <td><strong>@report.ReportName</strong></td>
                                <td>
                                    <span class="badge bg-info">@report.ReportType</span>
                                </td>
                                <td>
                                    <small>@report.GeneratedDate.ToString("g")</small>
                                </td>
                                <td>@report.GeneratedByName</td>
                                <td>
                                    <small class="text-muted">
                                        @if (report.StartDate.HasValue && report.EndDate.HasValue)
                                        {
                                            <span>@report.StartDate.Value.ToString("yyyy-MM-dd") to @report.EndDate.Value.ToString("yyyy-MM-dd")</span>
                                        }
                                        else
                                        {
                                            <span>N/A</span>
                                        }
                                    </small>
                                </td>
                                <td>
                                    <a href="@Url.Action("ViewReport", "Admin", new { id = report.ReportId })" class="btn btn-sm btn-info">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">
                                No reports found. <a href="@Url.Action("GenerateReport", "Admin")">Generate one</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
