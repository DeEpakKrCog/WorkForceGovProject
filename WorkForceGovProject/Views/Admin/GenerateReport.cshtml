@model ReportGenerationViewModel

@{
    ViewData["Title"] = "Generate Report";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-file-pdf"></i> Generate Report</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="GenerateReport">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="mb-3">
                            <label asp-for="ReportName" class="form-label">Report Name <span class="text-danger">*</span></label>
                            <input asp-for="ReportName" class="form-control" placeholder="e.g., Q1 Employment Report" />
                            <span asp-validation-for="ReportName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ReportType" class="form-label">Report Type <span class="text-danger">*</span></label>
                            <select asp-for="ReportType" class="form-select">
                                <option value="">-- Select Report Type --</option>
                                <option value="Employment">Employment Report</option>
                                <option value="Compliance">Compliance Report</option>
                                <option value="Participation">Participation Report</option>
                            </select>
                            <span asp-validation-for="ReportType" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="StartDate" class="form-label">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="EndDate" class="form-label">End Date</label>
                                <input asp-for="EndDate" type="date" class="form-control" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FilterCriteria" class="form-label">Additional Criteria</label>
                            <textarea asp-for="FilterCriteria" class="form-control" rows="3" placeholder="Specify any additional filtering criteria..."></textarea>
                            <small class="text-muted">Optional: You can add specific criteria to filter the report data</small>
                        </div>

                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i>
                            <strong>Note:</strong> The report will be generated based on the selected type and date range.
                            You can download or view it after generation.
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-file-pdf"></i> Generate Report
                            </button>
                            <a href="@Url.Action("Reports", "Admin")" class="btn btn-secondary">
                                <i class="fas fa-times"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
