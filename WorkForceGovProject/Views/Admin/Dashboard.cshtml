@model AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="admin-dashboard">
    <div class="container-fluid mt-4">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-md-12">
                <h1 class="page-title">
                    <i class="fas fa-tachometer-alt"></i> Administrator Dashboard
                </h1>
                <p class="text-muted">Welcome back! Here's an overview of your system.</p>
            </div>
        </div>

        <!-- Statistics Cards -->
        <div class="row mb-4">
            <div class="col-md-3 mb-3">
                <div class="card stats-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-title mb-1">Total Users</p>
                                <h3 class="mb-0">@Model.TotalUsers</h3>
                            </div>
                            <i class="fas fa-users fa-2x text-primary"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card stats-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-title mb-1">Active Users</p>
                                <h3 class="mb-0 text-success">@Model.ActiveUsers</h3>
                            </div>
                            <i class="fas fa-user-check fa-2x text-success"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card stats-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-title mb-1">Inactive Users</p>
                                <h3 class="mb-0 text-warning">@Model.InactiveUsers</h3>
                            </div>
                            <i class="fas fa-user-slash fa-2x text-warning"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-3">
                <div class="card stats-card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <p class="card-title mb-1">Total Roles</p>
                                <h3 class="mb-0 text-info">@Model.TotalRoles</h3>
                            </div>
                            <i class="fas fa-user-tag fa-2x text-info"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="row mb-4">
            <div class="col-md-12">
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="fas fa-bolt"></i> Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <a href="@Url.Action("CreateUser", "Admin")" class="btn btn-primary btn-sm me-2">
                            <i class="fas fa-user-plus"></i> Create User
                        </a>
                        <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-info btn-sm me-2">
                            <i class="fas fa-users"></i> Manage Users
                        </a>
                        <a href="@Url.Action("ManageRoles", "Admin")" class="btn btn-secondary btn-sm me-2">
                            <i class="fas fa-user-tag"></i> Manage Roles
                        </a>
                        <a href="@Url.Action("SystemMonitoring", "Admin")" class="btn btn-warning btn-sm me-2">
                            <i class="fas fa-chart-line"></i> System Monitoring
                        </a>
                        <a href="@Url.Action("Reports", "Admin")" class="btn btn-success btn-sm">
                            <i class="fas fa-file-pdf"></i> Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity -->
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0"><i class="fas fa-history"></i> Recent System Activity</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.RecentLogs.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <tbody>
                                        @foreach (var log in Model.RecentLogs.Take(5))
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@log.Action</strong><br />
                                                    <small class="text-muted">@log.Timestamp.ToString("g")</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-secondary">@log.Resource</span>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-3 text-center text-muted">
                                No recent activity
                            </div>
                        }
                    </div>
                    <div class="card-footer text-center">
                        <a href="@Url.Action("SystemMonitoring", "Admin")" class="btn btn-sm btn-link">View All <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-header bg-success text-white">
                        <h5 class="mb-0"><i class="fas fa-user-plus"></i> Recently Added Users</h5>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.RecentUsers.Any())
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <tbody>
                                        @foreach (var user in Model.RecentUsers.Take(5))
                                        {
                                            <tr>
                                                <td>
                                                    <strong>@user.FullName</strong><br />
                                                    <small class="text-muted">@user.Email</small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-primary">@user.Role</span>
                                                    <br />
                                                    <small>@user.CreatedAt.ToString("g")</small>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="p-3 text-center text-muted">
                                No users added yet
                            </div>
                        }
                    </div>
                    <div class="card-footer text-center">
                        <a href="@Url.Action("ManageUsers", "Admin")" class="btn btn-sm btn-link">View All <i class="fas fa-arrow-right"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .admin-dashboard {
        background-color: #f8f9fa;
        min-height: calc(100vh - 100px);
        padding: 20px 0;
    }

    .page-title {
        color: #2c3e50;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .stats-card {
        border-left: 4px solid #007bff;
        transition: transform 0.2s;
    }

    .stats-card:hover {
        transform: translateY(-5px);
    }

    .card-title {
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 500;
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }
</style>
