@model WorkForceGovProject.Models.JobOpening

@{
    ViewData["Title"] = "Post New Job";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-plus-circle-fill me-2"></i>Post a New Job Opening
                    </h3>
                    <p class="mb-0 mt-2 opacity-75">Fill in the details to create a new job posting</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="CreateJob" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-semibold">
                                <i class="bi bi-briefcase text-primary"></i> Job Title <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g., Senior Software Developer" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">
                                <i class="bi bi-card-text text-primary"></i> Job Description <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="6" 
                                      placeholder="Describe the role, responsibilities, and what you're looking for..."></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                            <div class="form-text">Provide a detailed description of the job role and responsibilities</div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label fw-semibold">
                                    <i class="bi bi-geo-alt text-primary"></i> Location <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Location" class="form-control" placeholder="City, State or Remote" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Salary" class="form-label fw-semibold">
                                    <i class="bi bi-currency-dollar text-primary"></i> Salary
                                </label>
                                <input asp-for="Salary" class="form-control" type="number" step="0.01" placeholder="Annual salary" />
                                <span asp-validation-for="Salary" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Requirements" class="form-label fw-semibold">
                                <i class="bi bi-list-check text-primary"></i> Requirements
                            </label>
                            <textarea asp-for="Requirements" class="form-control" rows="4" 
                                      placeholder="List required skills, qualifications, and experience..."></textarea>
                            <span asp-validation-for="Requirements" class="text-danger small"></span>
                            <div class="form-text">Specify education, skills, experience, and other requirements</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ApplicationDeadline" class="form-label fw-semibold">
                                <i class="bi bi-calendar-event text-primary"></i> Application Deadline
                            </label>
                            <input asp-for="ApplicationDeadline" class="form-control" type="date" 
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                            <span asp-validation-for="ApplicationDeadline" class="text-danger small"></span>
                            <div class="form-text">Last date for accepting applications</div>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Note:</strong> Your job posting will be visible to all job seekers once published.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Dashboard" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5">
                                <i class="bi bi-check-circle-fill me-2"></i>Publish Job
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Tips Card -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-lightbulb text-warning"></i> Tips for Creating a Great Job Posting
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0">
                        <li class="mb-2"><strong>Be Clear:</strong> Use a specific job title that accurately describes the position</li>
                        <li class="mb-2"><strong>Be Detailed:</strong> Include key responsibilities and day-to-day tasks</li>
                        <li class="mb-2"><strong>Be Specific:</strong> List required skills, qualifications, and experience levels</li>
                        <li class="mb-2"><strong>Be Attractive:</strong> Highlight company culture, benefits, and growth opportunities</li>
                        <li><strong>Be Realistic:</strong> Set appropriate salary ranges and requirements</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
