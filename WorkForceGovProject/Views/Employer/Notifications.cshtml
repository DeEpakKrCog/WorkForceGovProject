@model IEnumerable<WorkForceGovProject.Models.Notification>

@{
    ViewData["Title"] = "Notifications";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-bell-fill text-primary"></i> Notifications
                    </h2>
                    <p class="text-muted mb-0">Stay updated with your recruitment activities</p>
                </div>
                @if (Model.Any(n => n.Status == "Unread"))
                {
                    <form asp-action="MarkAllNotificationsAsRead" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-primary">
                            <i class="bi bi-check-all me-2"></i>Mark All as Read
                        </button>
                    </form>
                }
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center py-5">
            <div class="card-body">
                <i class="bi bi-bell-slash text-muted" style="font-size: 5rem;"></i>
                <h3 class="mt-4 mb-3">No Notifications</h3>
                <p class="text-muted mb-4">You're all caught up! Check back later for updates.</p>
                <a asp-action="Dashboard" class="btn btn-primary">
                    <i class="bi bi-house me-2"></i>Go to Dashboard
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8 mx-auto">
                @foreach (var notification in Model)
                {
                    <div class="card shadow-sm border-0 mb-3 @(notification.Status == "Unread" ? "border-start border-primary border-4" : "")">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start">
                                <div class="flex-grow-1">
                                    <div class="d-flex align-items-center mb-2">
                                        @switch (notification.Category)
                                        {
                                            case "Job Application":
                                                <div class="bg-info bg-opacity-10 text-info rounded-circle p-2 me-3">
                                                    <i class="bi bi-file-earmark-text-fill fs-4"></i>
                                                </div>
                                                break;
                                            case "Application Update":
                                                <div class="bg-warning bg-opacity-10 text-warning rounded-circle p-2 me-3">
                                                    <i class="bi bi-clock-fill fs-4"></i>
                                                </div>
                                                break;
                                            case "Hiring":
                                                <div class="bg-success bg-opacity-10 text-success rounded-circle p-2 me-3">
                                                    <i class="bi bi-person-check-fill fs-4"></i>
                                                </div>
                                                break;
                                            case "Document Verification":
                                                <div class="bg-purple bg-opacity-10 text-purple rounded-circle p-2 me-3">
                                                    <i class="bi bi-file-earmark-check-fill fs-4"></i>
                                                </div>
                                                break;
                                            default:
                                                <div class="bg-secondary bg-opacity-10 text-secondary rounded-circle p-2 me-3">
                                                    <i class="bi bi-info-circle-fill fs-4"></i>
                                                </div>
                                                break;
                                        }
                                        <div>
                                            <h6 class="mb-0 fw-bold @(notification.Status == "Unread" ? "text-primary" : "")">
                                                @notification.Category
                                            </h6>
                                            <small class="text-muted">
                                                <i class="bi bi-clock me-1"></i>
                                                @notification.CreatedDate.ToString("MMM dd, yyyy - hh:mm tt")
                                            </small>
                                        </div>
                                    </div>

                                    <p class="mb-2 ms-5">@notification.Message</p>

                                    @if (notification.Status == "Unread")
                                    {
                                        <span class="badge bg-primary ms-5">New</span>
                                    }
                                </div>

                                <div class="dropdown">
                                    <button class="btn btn-sm btn-link text-muted" type="button" data-bs-toggle="dropdown">
                                        <i class="bi bi-three-dots-vertical"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        @if (notification.Status == "Unread")
                                        {
                                            <li>
                                                <form asp-action="MarkNotificationAsRead" asp-route-id="@notification.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="dropdown-item">
                                                        <i class="bi bi-check me-2"></i>Mark as Read
                                                    </button>
                                                </form>
                                            </li>
                                        }
                                        <li>
                                            <form asp-action="DeleteNotification" asp-route-id="@notification.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Delete this notification?')">
                                                    <i class="bi bi-trash me-2"></i>Delete
                                                </button>
                                            </form>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .text-purple {
            color: #764ba2;
        }
        .bg-purple {
            background-color: #764ba2;
        }
    </style>
}
