@model IEnumerable<WorkForceGovProject.Models.Application>

@{
    ViewData["Title"] = "Applications";
    var jobTitle = ViewBag.JobTitle as string;
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-file-earmark-text-fill text-primary"></i> 
                        @(jobTitle != null ? $"Applications for {jobTitle}" : "All Applications")
                    </h2>
                    <p class="text-muted mb-0">Review and manage candidate applications</p>
                </div>
                @if (jobTitle != null)
                {
                    <a asp-action="Applications" class="btn btn-outline-primary">
                        <i class="bi bi-arrow-left me-2"></i>View All Applications
                    </a>
                }
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Filter Tabs -->
    <ul class="nav nav-pills mb-4" id="applicationTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="all-tab" data-bs-toggle="pill" data-bs-target="#all" type="button">
                <i class="bi bi-list-ul me-1"></i>All Applications
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pending-tab" data-bs-toggle="pill" data-bs-target="#pending" type="button">
                <i class="bi bi-clock me-1"></i>Pending
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="shortlisted-tab" data-bs-toggle="pill" data-bs-target="#shortlisted" type="button">
                <i class="bi bi-star me-1"></i>Shortlisted
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="approved-tab" data-bs-toggle="pill" data-bs-target="#approved" type="button">
                <i class="bi bi-check-circle me-1"></i>Approved
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="rejected-tab" data-bs-toggle="pill" data-bs-target="#rejected" type="button">
                <i class="bi bi-x-circle me-1"></i>Rejected
            </button>
        </li>
    </ul>

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center py-5">
            <div class="card-body">
                <i class="bi bi-inbox text-muted" style="font-size: 5rem;"></i>
                <h3 class="mt-4 mb-3">No Applications Yet</h3>
                <p class="text-muted mb-4">Applications will appear here once candidates start applying</p>
                <a asp-action="ManageJobs" class="btn btn-primary">
                    <i class="bi bi-briefcase me-2"></i>View Your Job Postings
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="tab-content" id="applicationTabsContent">
            <!-- All Applications -->
            <div class="tab-pane fade show active" id="all" role="tabpanel">
                @await Html.PartialAsync("_ApplicationsList", Model)
            </div>

            <!-- Pending Applications -->
            <div class="tab-pane fade" id="pending" role="tabpanel">
                @await Html.PartialAsync("_ApplicationsList", Model.Where(a => a.Status == "Pending"))
            </div>

            <!-- Shortlisted Applications -->
            <div class="tab-pane fade" id="shortlisted" role="tabpanel">
                @await Html.PartialAsync("_ApplicationsList", Model.Where(a => a.Status == "Shortlisted"))
            </div>

            <!-- Approved Applications -->
            <div class="tab-pane fade" id="approved" role="tabpanel">
                @await Html.PartialAsync("_ApplicationsList", Model.Where(a => a.Status == "Approved"))
            </div>

            <!-- Rejected Applications -->
            <div class="tab-pane fade" id="rejected" role="tabpanel">
                @await Html.PartialAsync("_ApplicationsList", Model.Where(a => a.Status == "Rejected"))
            </div>
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
