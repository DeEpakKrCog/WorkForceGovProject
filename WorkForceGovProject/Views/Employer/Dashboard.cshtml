@model WorkForceGovProject.Models.Employer

@{
    ViewData["Title"] = "Employer Dashboard";
}

<div class="container-fluid mt-4">
    <!-- Welcome Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0 bg-gradient-primary text-white">
                <div class="card-body">
                    <h2 class="mb-2">
                        <i class="bi bi-building"></i> Welcome, @Model.CompanyName!
                    </h2>
                    <p class="mb-0">
                        <i class="bi bi-info-circle"></i> Status: 
                        <span class="badge @(Model.Status == "Verified" ? "bg-success" : Model.Status == "Pending" ? "bg-warning" : "bg-secondary")">
                            @Model.Status
                        </span>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-4 mb-4">
        <!-- Total Job Postings -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-3 p-3">
                                <i class="bi bi-briefcase-fill fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Job Postings</h6>
                            <h3 class="mb-0 fw-bold">@ViewBag.TotalJobPostings</h3>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-action="ManageJobs" class="text-decoration-none small">
                        View all jobs <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Active Jobs -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-opacity-10 text-success rounded-3 p-3">
                                <i class="bi bi-check-circle-fill fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Active Jobs</h6>
                            <h3 class="mb-0 fw-bold text-success">@ViewBag.ActiveJobPostings</h3>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-action="CreateJob" class="text-decoration-none small">
                        Post new job <i class="bi bi-plus-circle"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Total Applicants -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-opacity-10 text-info rounded-3 p-3">
                                <i class="bi bi-people-fill fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Total Applicants</h6>
                            <h3 class="mb-0 fw-bold text-info">@ViewBag.TotalApplicants</h3>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-action="Applications" class="text-decoration-none small">
                        View applications <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- Pending Applications -->
        <div class="col-xl-3 col-md-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-warning bg-opacity-10 text-warning rounded-3 p-3">
                                <i class="bi bi-clock-fill fs-2"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h6 class="text-muted mb-1">Pending Applications</h6>
                            <h3 class="mb-0 fw-bold text-warning">@ViewBag.PendingApplications</h3>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a asp-action="Applications" class="text-decoration-none small">
                        Review now <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Secondary Statistics -->
    <div class="row g-4 mb-4">
        <!-- Shortlisted Candidates -->
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-purple bg-opacity-10 text-purple rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-star-fill fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.ShortlistedCandidates</h3>
                    <p class="text-muted mb-0">Shortlisted Candidates</p>
                    <a asp-action="ShortlistedCandidates" class="btn btn-outline-primary btn-sm mt-3">
                        View Shortlist
                    </a>
                </div>
            </div>
        </div>

        <!-- Hired Candidates -->
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-person-check-fill fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.HiredCandidates</h3>
                    <p class="text-muted mb-0">Hired Candidates</p>
                    <a asp-action="Applications" class="btn btn-outline-success btn-sm mt-3">
                        View Hired
                    </a>
                </div>
            </div>
        </div>

        <!-- Notifications -->
        <div class="col-lg-4 col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-body text-center">
                    <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                        <i class="bi bi-bell-fill fs-4"></i>
                    </div>
                    <h3 class="fw-bold mb-1">@ViewBag.UnreadNotifications</h3>
                    <p class="text-muted mb-0">Unread Notifications</p>
                    <a asp-action="Notifications" class="btn btn-outline-danger btn-sm mt-3">
                        View Notifications
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-lightning-charge-fill text-primary"></i> Quick Actions
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-3 col-md-6">
                            <a asp-action="CreateJob" class="btn btn-primary w-100 py-3">
                                <i class="bi bi-plus-circle-fill me-2"></i>Post New Job
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <a asp-action="Applications" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-file-earmark-text me-2"></i>View Applications
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <a asp-action="ManageJobs" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-briefcase me-2"></i>Manage Jobs
                            </a>
                        </div>
                        <div class="col-lg-3 col-md-6">
                            <a asp-action="Profile" class="btn btn-outline-primary w-100 py-3">
                                <i class="bi bi-person-circle me-2"></i>Edit Profile
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Company Information -->
    <div class="row">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-building text-primary"></i> Company Information
                    </h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-3">
                            <strong class="text-muted">Industry:</strong>
                            <span class="ms-2">@Model.Industry</span>
                        </li>
                        <li class="mb-3">
                            <strong class="text-muted">Status:</strong>
                            <span class="ms-2 badge @(Model.Status == "Verified" ? "bg-success" : Model.Status == "Pending" ? "bg-warning" : "bg-secondary")">
                                @Model.Status
                            </span>
                        </li>
                        <li class="mb-3">
                            <strong class="text-muted">Contact:</strong>
                            <span class="ms-2">@Model.ContactInfo</span>
                        </li>
                        <li class="mb-3">
                            <strong class="text-muted">Address:</strong>
                            <span class="ms-2">@Model.Address</span>
                        </li>
                        <li class="mb-0">
                            <strong class="text-muted">Registered:</strong>
                            <span class="ms-2">@Model.RegistrationDate.ToString("MMMM dd, yyyy")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h5 class="mb-0 fw-bold">
                        <i class="bi bi-graph-up text-success"></i> Recent Activity
                    </h5>
                </div>
                <div class="card-body">
                    @if (Model.Status == "Pending")
                    {
                        <div class="alert alert-warning mb-3" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <strong>Account Pending Verification</strong>
                            <p class="mb-0 small mt-2">
                                Your account is currently under review. Please upload required documents to complete verification.
                            </p>
                            <a asp-action="Documents" class="btn btn-sm btn-warning mt-2">
                                <i class="bi bi-upload"></i> Upload Documents
                            </a>
                        </div>
                    }
                    <div class="d-grid gap-2">
                        <a asp-action="Documents" class="btn btn-outline-secondary">
                            <i class="bi bi-file-earmark-arrow-up me-2"></i>Manage Documents
                        </a>
                        <a asp-action="Notifications" class="btn btn-outline-secondary">
                            <i class="bi bi-bell me-2"></i>View All Notifications
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .bg-gradient-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
        .text-purple {
            color: #764ba2;
        }
        .bg-purple {
            background-color: #764ba2;
        }
        .card {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
    </style>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
