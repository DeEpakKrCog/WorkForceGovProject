@model WorkForceGovProject.Models.Employer

@{
    ViewData["Title"] = "Employer Registration";
    Layout = "_Layout";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-gradient-primary text-white py-4">
                    <div class="text-center">
                        <i class="bi bi-building-fill" style="font-size: 3rem;"></i>
                        <h2 class="mt-3 mb-2 fw-bold">Employer Registration</h2>
                        <p class="mb-0 opacity-75">Join our platform to hire talented professionals</p>
                    </div>
                </div>
                <div class="card-body p-5">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <!-- Company Information Section -->
                        <h5 class="fw-bold mb-4 text-primary">
                            <i class="bi bi-building me-2"></i>Company Information
                        </h5>

                        <div class="mb-4">
                            <label asp-for="CompanyName" class="form-label fw-semibold">
                                Company Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CompanyName" class="form-control form-control-lg" placeholder="Enter your company name" />
                            <span asp-validation-for="CompanyName" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Industry" class="form-label fw-semibold">
                                Industry <span class="text-danger">*</span>
                            </label>
                            <select asp-for="Industry" class="form-select form-select-lg">
                                <option value="">Select Industry</option>
                                <option value="Information Technology">Information Technology</option>
                                <option value="Healthcare">Healthcare</option>
                                <option value="Finance">Finance</option>
                                <option value="Education">Education</option>
                                <option value="Manufacturing">Manufacturing</option>
                                <option value="Retail">Retail</option>
                                <option value="Construction">Construction</option>
                                <option value="Transportation">Transportation</option>
                                <option value="Hospitality">Hospitality</option>
                                <option value="Agriculture">Agriculture</option>
                                <option value="Real Estate">Real Estate</option>
                                <option value="Telecommunications">Telecommunications</option>
                                <option value="Other">Other</option>
                            </select>
                            <span asp-validation-for="Industry" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ContactInfo" class="form-label fw-semibold">
                                Contact Information <span class="text-danger">*</span>
                            </label>
                            <input asp-for="ContactInfo" class="form-control form-control-lg" placeholder="Phone number or email" />
                            <span asp-validation-for="ContactInfo" class="text-danger small"></span>
                            <div class="form-text">Primary contact number or email for communication</div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Address" class="form-label fw-semibold">
                                Company Address <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Address" class="form-control" rows="3" placeholder="Complete business address"></textarea>
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <hr class="my-4">

                        <!-- Account Credentials Section -->
                        <h5 class="fw-bold mb-4 text-primary">
                            <i class="bi bi-shield-lock me-2"></i>Account Credentials
                        </h5>

                        <div class="mb-4">
                            <label for="email" class="form-label fw-semibold">
                                Email Address <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                <input type="email" class="form-control" id="email" name="email" placeholder="company@example.com" required />
                            </div>
                            <div class="form-text">This will be used as your login username</div>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label fw-semibold">
                                Password <span class="text-danger">*</span>
                            </label>
                            <div class="input-group input-group-lg">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input type="password" class="form-control" id="password" name="password" 
                                       placeholder="Enter a strong password" required minlength="6" />
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                    <i class="bi bi-eye"></i>
                                </button>
                            </div>
                            <div class="form-text">Minimum 6 characters, include numbers and special characters</div>
                        </div>

                        <div class="mb-4">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="terms" required>
                                <label class="form-check-label" for="terms">
                                    I agree to the <a href="#" class="text-primary">Terms and Conditions</a> 
                                    and <a href="#" class="text-primary">Privacy Policy</a>
                                </label>
                            </div>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Note:</strong> Your account will be pending verification. 
                            Please upload required documents after registration to complete the verification process.
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg py-3">
                                <i class="bi bi-check-circle-fill me-2"></i>Register as Employer
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-4">
                        <p class="text-muted mb-0">
                            Already have an account? 
                            <a asp-controller="Account" asp-action="Login" class="text-primary fw-semibold">Login here</a>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Benefits Card -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-star-fill text-warning"></i> Why Register as an Employer?
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Access Qualified Candidates</h6>
                                    <p class="text-muted small mb-0">Find verified and skilled professionals</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Easy Job Posting</h6>
                                    <p class="text-muted small mb-0">Post unlimited job openings</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Application Management</h6>
                                    <p class="text-muted small mb-0">Review and manage applications efficiently</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="d-flex">
                                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                                <div>
                                    <h6 class="fw-bold mb-1">Government Verified</h6>
                                    <p class="text-muted small mb-0">Trusted platform with verified candidates</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        // Toggle password visibility
        document.getElementById('togglePassword').addEventListener('click', function() {
            const passwordInput = document.getElementById('password');
            const icon = this.querySelector('i');
            
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                icon.classList.remove('bi-eye');
                icon.classList.add('bi-eye-slash');
            } else {
                passwordInput.type = 'password';
                icon.classList.remove('bi-eye-slash');
                icon.classList.add('bi-eye');
            }
        });
    </script>
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .bg-gradient-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }
    </style>
}
