@model WorkForceGovProject.Models.JobOpening

@{
    ViewData["Title"] = "Edit Job";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Job Opening
                    </h3>
                    <p class="mb-0 mt-2 opacity-75">Update job details and requirements</p>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <form asp-action="EditJob" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label asp-for="Title" class="form-label fw-semibold">
                                <i class="bi bi-briefcase text-success"></i> Job Title <span class="text-danger">*</span>
                            </label>
                            <input asp-for="Title" class="form-control form-control-lg" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-semibold">
                                <i class="bi bi-card-text text-success"></i> Job Description <span class="text-danger">*</span>
                            </label>
                            <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                            <span asp-validation-for="Description" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Location" class="form-label fw-semibold">
                                    <i class="bi bi-geo-alt text-success"></i> Location <span class="text-danger">*</span>
                                </label>
                                <input asp-for="Location" class="form-control" />
                                <span asp-validation-for="Location" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Salary" class="form-label fw-semibold">
                                    <i class="bi bi-currency-dollar text-success"></i> Salary
                                </label>
                                <input asp-for="Salary" class="form-control" type="number" step="0.01" />
                                <span asp-validation-for="Salary" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Requirements" class="form-label fw-semibold">
                                <i class="bi bi-list-check text-success"></i> Requirements
                            </label>
                            <textarea asp-for="Requirements" class="form-control" rows="4"></textarea>
                            <span asp-validation-for="Requirements" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="ApplicationDeadline" class="form-label fw-semibold">
                                    <i class="bi bi-calendar-event text-success"></i> Application Deadline
                                </label>
                                <input asp-for="ApplicationDeadline" class="form-control" type="date" />
                                <span asp-validation-for="ApplicationDeadline" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Status" class="form-label fw-semibold">
                                    <i class="bi bi-toggle-on text-success"></i> Status
                                </label>
                                <select asp-for="Status" class="form-select">
                                    <option value="Open">Open</option>
                                    <option value="Closed">Closed</option>
                                </select>
                                <span asp-validation-for="Status" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="alert alert-info" role="alert">
                            <i class="bi bi-info-circle-fill me-2"></i>
                            <strong>Note:</strong> Changes will be visible to all users immediately after saving.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="ManageJobs" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="bi bi-check-circle-fill me-2"></i>Update Job
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Job Info -->
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="small text-muted">Job ID</div>
                            <div class="fw-bold">#@Model.Id</div>
                        </div>
                        <div class="col-md-4">
                            <div class="small text-muted">Posted Date</div>
                            <div class="fw-bold">@Model.PostedDate.ToString("MMM dd, yyyy")</div>
                        </div>
                        <div class="col-md-4">
                            <div class="small text-muted">Current Status</div>
                            <div>
                                <span class="badge @(Model.Status == "Open" ? "bg-success" : "bg-secondary")">
                                    @Model.Status
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
}
