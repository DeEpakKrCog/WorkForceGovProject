@model IEnumerable<WorkForceGovProject.Models.Application>

@{
    ViewData["Title"] = "Shortlisted Candidates";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-star-fill text-warning"></i> Shortlisted Candidates
                    </h2>
                    <p class="text-muted mb-0">Review your top candidates for hiring</p>
                </div>
                <a asp-action="Applications" class="btn btn-outline-primary">
                    <i class="bi bi-arrow-left me-2"></i>All Applications
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center py-5">
            <div class="card-body">
                <i class="bi bi-star text-muted" style="font-size: 5rem;"></i>
                <h3 class="mt-4 mb-3">No Shortlisted Candidates</h3>
                <p class="text-muted mb-4">Start shortlisting candidates from your applications</p>
                <a asp-action="Applications" class="btn btn-primary">
                    <i class="bi bi-file-earmark-text me-2"></i>View Applications
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @{
                var applicationDetails = ViewBag.ApplicationDetails as IEnumerable<dynamic>;
            }
            @foreach (var detail in applicationDetails ?? Enumerable.Empty<dynamic>())
            {
                var app = detail.Application as WorkForceGovProject.Models.Application;
                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-gradient-warning text-white py-3">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-star-fill me-2 fs-5"></i>
                                <h5 class="mb-0">Shortlisted Candidate</h5>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <div class="text-center mb-4">
                                <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" 
                                     style="width: 80px; height: 80px;">
                                    <i class="bi bi-person-fill" style="font-size: 2.5rem;"></i>
                                </div>
                                <h4 class="fw-bold mb-1">@detail.CitizenName</h4>
                                <p class="text-muted mb-0">
                                    <i class="bi bi-envelope me-1"></i>@detail.CitizenEmail
                                </p>
                            </div>

                            <hr>

                            <div class="mb-3">
                                <div class="small text-muted mb-1">
                                    <i class="bi bi-briefcase"></i> Position Applied
                                </div>
                                <div class="fw-semibold">@detail.JobTitle</div>
                            </div>

                            <div class="row g-3 mb-4">
                                <div class="col-6">
                                    <div class="small text-muted">
                                        <i class="bi bi-calendar-event"></i> Applied
                                    </div>
                                    <div class="fw-semibold small">@app.SubmittedDate.ToString("MMM dd")</div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted">
                                        <i class="bi bi-hash"></i> App ID
                                    </div>
                                    <div class="fw-semibold small">#@app.Id</div>
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <a asp-action="ApplicationDetails" asp-route-id="@app.Id" class="btn btn-primary">
                                    <i class="bi bi-eye me-2"></i>View Full Profile
                                </a>
                                <form asp-action="ApproveApplication" asp-route-id="@app.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-success" onclick="return confirm('Are you sure you want to hire this candidate?')">
                                        <i class="bi bi-check-circle-fill me-2"></i>Hire Now
                                    </button>
                                </form>
                                <form asp-action="RejectApplication" asp-route-id="@app.Id" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Remove from shortlist?')">
                                        <i class="bi bi-x-circle me-1"></i>Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .bg-gradient-warning {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        }
        .card {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
    </style>
}
