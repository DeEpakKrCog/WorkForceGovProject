@model IEnumerable<WorkForceGovProject.Models.JobOpening>

@{
    ViewData["Title"] = "Manage Job Listings";
}

<div class="container-fluid mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold mb-2">
                        <i class="bi bi-briefcase-fill text-primary"></i> Manage Job Listings
                    </h2>
                    <p class="text-muted mb-0">View, edit, and manage all your job postings</p>
                </div>
                <a asp-action="CreateJob" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle-fill me-2"></i>Post New Job
                </a>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card shadow-sm border-0 text-center py-5">
            <div class="card-body">
                <i class="bi bi-briefcase text-muted" style="font-size: 5rem;"></i>
                <h3 class="mt-4 mb-3">No Job Postings Yet</h3>
                <p class="text-muted mb-4">Start hiring by creating your first job posting</p>
                <a asp-action="CreateJob" class="btn btn-primary btn-lg">
                    <i class="bi bi-plus-circle-fill me-2"></i>Create Your First Job
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var job in Model)
            {
                <div class="col-lg-6 mb-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-white border-0 py-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h5 class="mb-1 fw-bold">@job.Title</h5>
                                    <p class="text-muted mb-0 small">
                                        <i class="bi bi-geo-alt me-1"></i>@job.Location
                                    </p>
                                </div>
                                <span class="badge @(job.Status == "Open" ? "bg-success" : "bg-secondary") fs-6">
                                    @job.Status
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <p class="card-text text-muted">
                                @(job.Description.Length > 150 ? job.Description.Substring(0, 150) + "..." : job.Description)
                            </p>

                            <div class="row g-3 mb-3">
                                <div class="col-6">
                                    <div class="small text-muted">
                                        <i class="bi bi-currency-dollar"></i> Salary
                                    </div>
                                    <div class="fw-semibold">
                                        @(job.Salary > 0 ? job.Salary.ToString("C") : "Not specified")
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="small text-muted">
                                        <i class="bi bi-calendar-event"></i> Posted
                                    </div>
                                    <div class="fw-semibold">@job.PostedDate.ToString("MMM dd, yyyy")</div>
                                </div>
                            </div>

                            @if (job.ApplicationDeadline.HasValue)
                            {
                                <div class="alert alert-warning py-2 px-3 small mb-3">
                                    <i class="bi bi-clock-fill me-1"></i>
                                    Deadline: @job.ApplicationDeadline.Value.ToString("MMMM dd, yyyy")
                                </div>
                            }

                            <div class="d-flex gap-2 flex-wrap">
                                <a asp-action="Applications" asp-route-jobId="@job.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-people me-1"></i>View Applications
                                </a>
                                <a asp-action="EditJob" asp-route-id="@job.Id" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-pencil me-1"></i>Edit
                                </a>
                                @if (job.Status == "Open")
                                {
                                    <form asp-action="CloseJob" asp-route-id="@job.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-warning btn-sm" onclick="return confirm('Are you sure you want to close this job?')">
                                            <i class="bi bi-lock me-1"></i>Close
                                        </button>
                                    </form>
                                }
                                <form asp-action="DeleteJob" asp-route-id="@job.Id" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" onclick="return confirm('Are you sure you want to delete this job? This action cannot be undone.')">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                        <div class="card-footer bg-light border-0 py-2">
                            <small class="text-muted">
                                <i class="bi bi-info-circle me-1"></i>
                                Job ID: #@job.Id
                            </small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        .card {
            transition: transform 0.2s, box-shadow 0.2s;
        }
        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
        }
    </style>
}
