@{
    ViewData["Title"] = "Compliance Officer Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h1 class="display-5 fw-bold text-primary">
                <i class="fas fa-shield-alt"></i> Compliance Officer Dashboard
            </h1>
            <p class="text-muted">Monitor employer compliance and manage violations</p>
        </div>
    </div>

    <!-- Dashboard Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Pending Reviews</small>
                            <h3 class="fw-bold text-primary mt-2">@ViewBag.PendingCount</h3>
                        </div>
                        <i class="fas fa-hourglass-half text-warning" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Violations Recorded</small>
                            <h3 class="fw-bold text-danger mt-2">@ViewBag.ViolationCount</h3>
                        </div>
                        <i class="fas fa-exclamation-circle text-danger" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Compliance Rate</small>
                            <h3 class="fw-bold text-success mt-2">92%</h3>
                        </div>
                        <i class="fas fa-chart-pie text-success" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-light">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <small class="text-muted text-uppercase fw-bold">Employers Monitored</small>
                            <h3 class="fw-bold text-info mt-2">156</h3>
                        </div>
                        <i class="fas fa-building text-info" style="font-size: 2rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-primary text-white fw-bold">
                    <i class="fas fa-tasks"></i> Quick Actions
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-action="EmployerReview" class="btn btn-outline-primary" style="justify-content: flex-start;">
                            <i class="fas fa-search me-2"></i> Review Employer Compliance
                        </a>
                        <a asp-action="InvestigateComplaint" class="btn btn-outline-primary" style="justify-content: flex-start;">
                            <i class="fas fa-magnifying-glass me-2"></i> Investigate Complaints
                        </a>
                        <a asp-action="RecordViolation" class="btn btn-outline-danger" style="justify-content: flex-start;">
                            <i class="fas fa-ban me-2"></i> Record Violation
                        </a>
                        <a asp-action="ComplianceReports" class="btn btn-outline-success" style="justify-content: flex-start;">
                            <i class="fas fa-file-pdf me-2"></i> Generate Reports
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-warning text-dark fw-bold">
                    <i class="fas fa-bell"></i> Recent Complaints (@ViewBag.Complaints?.Count ?? 0)
                </div>
                <div class="card-body">
                    @if (ViewBag.Complaints?.Count > 0)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var complaint in ViewBag.Complaints.Take(5))
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <small class="text-muted">Complaint ID: #@complaint.Id</small>
                                        <p class="mb-0 fw-500">@complaint.Notes?.Substring(0, Math.Min(50, complaint.Notes?.Length ?? 0))...</p>
                                    </div>
                                    <span class="badge bg-warning text-dark">Pending</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted text-center">No recent complaints</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Compliance Metrics Chart -->
    <div class="row">
        <div class="col-md-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-info text-white fw-bold">
                    <i class="fas fa-chart-line"></i> Compliance Trend
                </div>
                <div class="card-body">
                    <canvas id="complianceChart" height="80"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('complianceChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['Week 1', 'Week 2', 'Week 3', 'Week 4', 'Week 5', 'Week 6'],
                datasets: [{
                    label: 'Compliance Rate (%)',
                    data: [85, 87, 89, 91, 90, 92],
                    borderColor: '#17a2b8',
                    backgroundColor: 'rgba(23, 162, 184, 0.1)',
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: true }
                }
            }
        });
    </script>
}
