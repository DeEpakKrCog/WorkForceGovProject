@model WorkForceGovProject.Models.Citizen
@{
    ViewData["Title"] = "Register Citizen";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/CreateProgram.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="Citizen">🏠 Dashboard</a>
        <a href="#" class="active">👤 Register Citizen</a>
        <a asp-action="Dashboard" asp-controller="ProgramManager">📋 Program Manager</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Register New Citizen</h2>
                <p class="text-muted">Add a new citizen to the workforce system</p>
            </div>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <form asp-action="CreateCitizen" asp-controller="Citizen" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <!-- Full Name -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="FullName" class="form-label fw-bold">Full Name <span class="text-danger">*</span></label>
                            <input asp-for="FullName" class="form-control form-control-lg" placeholder="Enter full name" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Email" class="form-label fw-bold">Email Address <span class="text-danger">*</span></label>
                            <input asp-for="Email" type="email" class="form-control" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Information Box -->
                <div class="alert alert-info d-flex align-items-center mt-4" role="alert">
                    <i class="bi bi-info-circle-fill me-2" style="font-size: 1.5rem;"></i>
                    <div>
                        <strong>Note:</strong> After registration, the following default values will be set:
                        <ul class="mb-0 mt-2">
                            <li>Active Applications: 0</li>
                            <li>Account Balance: $0.00</li>
                            <li>Document Status: Pending</li>
                            <li>Job Matches: 0</li>
                        </ul>
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                    <button type="submit" class="btn btn-lg btn-primary px-5 shadow-sm">
                        <i class="bi bi-check-circle"></i> Register Citizen
                    </button>
                </div>
            </form>
        </div>

        <!-- Help Section -->
        <div class="bg-light rounded-3 border p-4 mt-4">
            <h5 class="fw-bold mb-3">
                <i class="bi bi-question-circle text-primary"></i> Registration Guidelines
            </h5>
            <div class="row">
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Full Name:</strong> Enter the citizen's complete legal name
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Email:</strong> Provide a valid email address for notifications
                        </li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Verification:</strong> Documents will be verified later
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check-circle-fill text-success me-2"></i>
                            <strong>Benefits:</strong> Citizens can receive program benefits after registration
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Recently Registered Citizens -->
        <div class="bg-white rounded-3 border shadow-sm p-4 mt-4">
            <h5 class="fw-bold mb-3">📋 Quick Registration Tips</h5>
            <div class="alert alert-light border">
                <p class="mb-2"><strong>✓</strong> Ensure email is unique (not already registered)</p>
                <p class="mb-2"><strong>✓</strong> Full name should include first and last name</p>
                <p class="mb-2"><strong>✓</strong> After registration, citizens appear in benefit distribution</p>
                <p class="mb-0"><strong>✓</strong> Citizens can update their profile after login</p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
