@model List<WorkForceGovProject.Models.Benefit>
@{
    ViewData["Title"] = "Government Benefits & Programs";
}

<style>
    .dashboard-container { display: flex; margin-top: -20px; min-height: 100vh; }
    .sidebar-nav { width: 260px; background: #1e293b; color: white; padding-top: 20px; }
    .sidebar-nav a { 
        display: block; padding: 12px 24px; color: #94a3b8; text-decoration: none; 
        transition: 0.3s; margin: 4px 12px; border-radius: 8px;
    }
    .sidebar-nav a:hover, .sidebar-nav a.active { background: #3b82f6; color: white; }
    .main-content { flex: 1; padding: 40px; background: #f8fafc; }
    .benefit-card { background: white; padding: 24px; border-radius: 12px; border-left: 4px solid #3b82f6; margin-bottom: 20px; }
    .benefit-amount { font-size: 24px; font-weight: bold; color: #059669; }
    .status-badge { display: inline-block; padding: 6px 12px; border-radius: 20px; font-size: 12px; font-weight: bold; }
    .status-active { background: #dcfce7; color: #166534; }
    .status-completed { background: #f3f4f6; color: #374151; }
</style>

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a href="#" class="active">🏠 Dashboard</a>
        <a asp-action="Profile" asp-controller="Citizen">👤 My Profile</a>
        <a asp-action="Documents" asp-controller="Citizen">📄 Verification Docs</a>
        <a asp-action="JobSearch" asp-controller="Citizen">🔍 Job Board</a>
        <a asp-action="JobApplications" asp-controller="Citizen">📋 My Applications</a>
        <a asp-action="Benefits" asp-controller="Citizen">💰 Benefits</a>
        <a asp-action="Notifications" asp-controller="Citizen">🔔 Notifications</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <h2 class="fw-bold text-dark mb-4">💰 Government Benefits & Programs</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <p class="mb-0">You are not currently enrolled in any government programs or benefits. Check back later for available opportunities.</p>
            </div>
        }
        else
        {
            <!-- Summary Stats -->
            <div class="row g-4 mb-5">
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted mb-2">Active Benefits</h6>
                            <p class="h3 fw-bold mb-0">@Model.Count(b => b.Status == "Active")</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted mb-2">Total Amount Received</h6>
                            <p class="h3 fw-bold mb-0 text-success">₹@Model.Sum(b => b.Amount).ToString("N0")</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card text-center">
                        <div class="card-body">
                            <h6 class="text-muted mb-2">Programs Enrolled</h6>
                            <p class="h3 fw-bold mb-0">@Model.Select(b => b.ProgramId).Distinct().Count()</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Benefits List -->
            @foreach (var benefit in Model.OrderByDescending(b => b.BenefitDate))
            {
                <div class="benefit-card">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h4 class="mb-1 fw-bold">@benefit.Program.ProgramName</h4>
                            <p class="text-muted mb-0">@benefit.BenefitType Benefit</p>
                        </div>
                        <span class="status-badge @(benefit.Status == "Active" ? "status-active" : "status-completed")">
                            @benefit.Status
                        </span>
                    </div>

                    <p class="text-secondary mb-3">@benefit.Program.Description</p>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <p class="mb-0"><strong>Amount Received:</strong></p>
                            <p class="benefit-amount">₹@benefit.Amount.ToString("N2")</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-0"><strong>Benefit Date:</strong> @benefit.BenefitDate.ToString("MMM dd, yyyy")</p>
                            <p class="mb-0"><strong>Type:</strong> @benefit.BenefitType</p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(benefit.Description))
                    {
                        <p class="text-muted">
                            <strong>Details:</strong> @benefit.Description
                        </p>
                    }
                </div>
            }
        }
    </div>
</div>
