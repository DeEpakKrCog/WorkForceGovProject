@model List<WorkForceGovProject.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<style>
    .dashboard-container { display: flex; margin-top: -20px; min-height: 100vh; }
    .sidebar-nav { width: 260px; background: #1e293b; color: white; padding-top: 20px; }
    .sidebar-nav a { 
        display: block; padding: 12px 24px; color: #94a3b8; text-decoration: none; 
        transition: 0.3s; margin: 4px 12px; border-radius: 8px;
    }
    .sidebar-nav a:hover, .sidebar-nav a.active { background: #3b82f6; color: white; }
    .main-content { flex: 1; padding: 40px; background: #f8fafc; }
    .notification-card { background: white; padding: 20px; border-radius: 12px; border-left: 4px solid #3b82f6; margin-bottom: 15px; cursor: pointer; transition: 0.3s; }
    .notification-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
    .notification-card.unread { background: #f0f9ff; border-left-color: #0284c7; }
    .category-badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: bold; }
    .cat-job { background: #dbeafe; color: #0c4a6e; }
    .cat-doc { background: #fef3c7; color: #92400e; }
    .cat-program { background: #dcfce7; color: #166534; }
    .cat-benefit { background: #fecdd3; color: #9f1239; }
</style>

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a href="#" class="active">🏠 Dashboard</a>
        <a asp-action="Profile" asp-controller="Citizen">👤 My Profile</a>
        <a asp-action="Documents" asp-controller="Citizen">📄 Verification Docs</a>
        <a asp-action="JobSearch" asp-controller="Citizen">🔍 Job Board</a>
        <a asp-action="JobApplications" asp-controller="Citizen">📋 My Applications</a>
        <a asp-action="Benefits" asp-controller="Citizen">💰 Benefits</a>
        <a asp-action="Notifications" asp-controller="Citizen">🔔 Notifications</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <h2 class="fw-bold text-dark mb-4">🔔 Notifications</h2>

        @if (!Model.Any())
        {
            <div class="alert alert-info">
                <p class="mb-0">No notifications at this time. You'll receive updates about your job applications, document verifications, and government programs here.</p>
            </div>
        }
        else
        {
            @foreach (var notification in Model)
            {
                <div class="notification-card @(!notification.IsRead ? "unread" : "")">
                    <div class="d-flex justify-content-between align-items-start">
                        <div class="flex-grow-1">
                            <div class="d-flex gap-2 mb-2 align-items-center">
                                @{
                                    string icon = notification.Category switch
                                    {
                                        "JobApplication" => "📋",
                                        "DocumentVerification" => "📄",
                                        "ProgramEnrollment" => "🎓",
                                        "BenefitApproval" => "💰",
                                        _ => "📢"
                                    };
                                }
                                <span>@icon</span>
                                <span class="category-badge 
                                    @(notification.Category == "JobApplication" ? "cat-job" :
                                      notification.Category == "DocumentVerification" ? "cat-doc" :
                                      notification.Category == "ProgramEnrollment" ? "cat-program" : "cat-benefit")">
                                    @notification.Category
                                </span>
                                @if (!notification.IsRead)
                                {
                                    <span class="badge bg-primary ms-2">New</span>
                                }
                            </div>
                            <p class="mb-1">@notification.Message</p>
                            <small class="text-muted">@notification.CreatedDate.ToString("MMM dd, yyyy h:mm tt")</small>
                        </div>
                        @if (!notification.IsRead)
                        {
                            <button type="button" class="btn btn-sm btn-outline-primary" 
                                    onclick="markAsRead(@notification.Id)">
                                Mark as Read
                            </button>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<script>
function markAsRead(notificationId) {
    fetch(`/Citizen/MarkNotificationAsRead`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({ notificationId: notificationId })
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            location.reload();
        }
    });
}
</script>
