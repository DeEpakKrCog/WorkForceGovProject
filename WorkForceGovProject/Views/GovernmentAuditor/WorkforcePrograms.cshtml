@{
    ViewData["Title"] = "Workforce Programs";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-briefcase"></i> Workforce Programs</h2>
            <p class="text-muted">Monitor and manage all employment programs</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Dashboard", "GovernmentAuditor")" class="btn btn-outline-primary">
                <i class="fas fa-arrow-left"></i> Back
            </a>
        </div>
    </div>

    <!-- Program Statistics -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-project-diagram fa-2x text-primary mb-2"></i>
                    <h6 class="card-title text-muted">Active Programs</h6>
                    <h3 class="text-primary">12</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-users fa-2x text-success mb-2"></i>
                    <h6 class="card-title text-muted">Total Participants</h6>
                    <h3 class="text-success">3,847</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-dollar-sign fa-2x text-warning mb-2"></i>
                    <h6 class="card-title text-muted">Total Budget</h6>
                    <h3 class="text-warning">$4.2M</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fas fa-chart-pie fa-2x text-info mb-2"></i>
                    <h6 class="card-title text-muted">Utilization</h6>
                    <h3 class="text-info">78%</h3>
                </div>
            </div>
        </div>
    </div>

    <!-- Programs List -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="fas fa-list"></i> Program Details</h5>
        </div>
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th><i class="fas fa-hashtag"></i> Program Name</th>
                        <th><i class="fas fa-users"></i> Participants</th>
                        <th><i class="fas fa-calendar"></i> Duration</th>
                        <th><i class="fas fa-chart-bar"></i> Progress</th>
                        <th><i class="fas fa-tools"></i> Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Job Training Initiative</strong></td>
                        <td><span class="badge bg-primary">856</span></td>
                        <td>12 Weeks</td>
                        <td>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: 85%;" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100">85%</div>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Apprenticeship Program</strong></td>
                        <td><span class="badge bg-primary">432</span></td>
                        <td>24 Weeks</td>
                        <td>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-info" role="progressbar" style="width: 62%;" aria-valuenow="62" aria-valuemin="0" aria-valuemax="100">62%</div>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Career Development</strong></td>
                        <td><span class="badge bg-primary">724</span></td>
                        <td>8 Weeks</td>
                        <td>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-warning" role="progressbar" style="width: 45%;" aria-valuenow="45" aria-valuemin="0" aria-valuemax="100">45%</div>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                    <tr>
                        <td><strong>Skills Certification</strong></td>
                        <td><span class="badge bg-primary">1,205</span></td>
                        <td>6 Weeks</td>
                        <td>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-success" role="progressbar" style="width: 92%;" aria-valuenow="92" aria-valuemin="0" aria-valuemax="100">92%</div>
                            </div>
                        </td>
                        <td>
                            <a href="#" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                            <a href="#" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
