@model WorkForceGovProject.Models.Audit

@{
    ViewData["Title"] = "Program Review";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0"><i class="fas fa-tasks"></i> Program Review</h4>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="ProgramReview">
                        <div class="alert alert-info" role="alert">
                            <i class="fas fa-info-circle"></i>
                            This is a comprehensive review of the workforce program implementation and outcomes.
                        </div>

                        <div class="mb-3">
                            <label for="programId" class="form-label fw-bold"><i class="fas fa-briefcase"></i> Program *</label>
                            <select class="form-select" id="programId" name="programId" required>
                                <option value="">-- Select Program --</option>
                                <option value="1">Job Training Initiative</option>
                                <option value="2">Apprenticeship Program</option>
                                <option value="3">Career Development</option>
                                <option value="4">Skills Certification</option>
                            </select>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="scope" class="form-label fw-bold"><i class="fas fa-expand"></i> Review Scope *</label>
                                <select class="form-select" id="scope" name="scope" required>
                                    <option value="">-- Select Scope --</option>
                                    <option value="Effectiveness">Effectiveness</option>
                                    <option value="Budget">Budget Utilization</option>
                                    <option value="Outcomes">Participant Outcomes</option>
                                    <option value="Compliance">Compliance</option>
                                    <option value="Full">Full Review</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="reviewDate" class="form-label fw-bold"><i class="fas fa-calendar"></i> Review Date *</label>
                                <input type="date" class="form-control" id="reviewDate" name="reviewDate" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="findings" class="form-label fw-bold"><i class="fas fa-pen-fancy"></i> Review Findings *</label>
                            <textarea class="form-control" id="findings" name="findings" rows="6" 
                                      placeholder="Document your findings, observations, and recommendations..." required></textarea>
                        </div>

                        <div class="mb-3">
                            <label for="recommendations" class="form-label fw-bold"><i class="fas fa-lightbulb"></i> Recommendations</label>
                            <textarea class="form-control" id="recommendations" name="recommendations" rows="4" 
                                      placeholder="Provide recommendations for improvement..."></textarea>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="rating" class="form-label fw-bold"><i class="fas fa-star"></i> Overall Rating *</label>
                                <select class="form-select" id="rating" name="rating" required>
                                    <option value="">-- Select Rating --</option>
                                    <option value="Excellent">Excellent</option>
                                    <option value="Good">Good</option>
                                    <option value="Satisfactory">Satisfactory</option>
                                    <option value="Needs Improvement">Needs Improvement</option>
                                    <option value="Poor">Poor</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="status" class="form-label fw-bold"><i class="fas fa-flag"></i> Status *</label>
                                <select class="form-select" id="status" name="status" required>
                                    <option value="">-- Select Status --</option>
                                    <option value="Open">Open</option>
                                    <option value="In Progress">In Progress</option>
                                    <option value="Pending">Pending Approval</option>
                                    <option value="Closed">Closed</option>
                                </select>
                            </div>
                        </div>

                        <hr>

                        <div class="row">
                            <div class="col-md-6">
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="fas fa-save"></i> Save Review
                                </button>
                            </div>
                            <div class="col-md-6">
                                <a href="@Url.Action("WorkforcePrograms", "GovernmentAuditor")" class="btn btn-secondary w-100">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-clipboard"></i> Review Checklist</h5>
                </div>
                <div class="card-body">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="check1">
                        <label class="form-check-label" for="check1">
                            <small>Program goals and objectives reviewed</small>
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="check2">
                        <label class="form-check-label" for="check2">
                            <small>Participant data analyzed</small>
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="check3">
                        <label class="form-check-label" for="check3">
                            <small>Budget utilization reviewed</small>
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="check4">
                        <label class="form-check-label" for="check4">
                            <small>Compliance requirements verified</small>
                        </label>
                    </div>
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" id="check5">
                        <label class="form-check-label" for="check5">
                            <small>Staff interviews completed</small>
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="check6">
                        <label class="form-check-label" for="check6">
                            <small>Documentation reviewed</small>
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
