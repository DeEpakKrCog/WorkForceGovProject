@model IEnumerable<WorkForceGovProject.Models.Audit>

@{
    ViewData["Title"] = "Audit Reports";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-file-audit"></i> Audit Reports</h2>
            <p class="text-muted">Complete history of all audits and reviews</p>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("CreateAudit", "GovernmentAuditor")" class="btn btn-primary">
                <i class="fas fa-plus"></i> New Audit
            </a>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0"><i class="fas fa-filter"></i> Filter Audits</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <input type="text" class="form-control" placeholder="Search by scope..." id="searchInput">
                </div>
                <div class="col-md-4">
                    <select class="form-select">
                        <option value="">-- All Status --</option>
                        <option value="Open">Open</option>
                        <option value="Pending">Pending</option>
                        <option value="Completed">Completed</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-primary w-100"><i class="fas fa-search"></i> Filter</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Audits List -->
    @if (Model.Any())
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="fas fa-list"></i> All Audits</h5>
            </div>
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th><i class="fas fa-hashtag"></i> ID</th>
                            <th><i class="fas fa-expand"></i> Scope</th>
                            <th><i class="fas fa-align-left"></i> Findings</th>
                            <th><i class="fas fa-flag"></i> Status</th>
                            <th><i class="fas fa-calendar"></i> Date</th>
                            <th><i class="fas fa-tools"></i> Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var audit in Model)
                        {
                            <tr>
                                <td>
                                    <span class="badge bg-secondary">@audit.AuditID</span>
                                </td>
                                <td>
                                    <span class="badge bg-info">@audit.Scope</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(audit.Findings))
                                    {
                                        <span>@audit.Findings.Substring(0, Math.Min(50, audit.Findings.Length))...</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No findings yet</span>
                                    }
                                </td>
                                <td>
                                    @{
                                        var statusBadge = audit.Status switch
                                        {
                                            "Open" => "bg-warning",
                                            "Closed" => "bg-success",
                                            "Pending" => "bg-info",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusBadge">@audit.Status</span>
                                </td>
                                <td>@audit.Date.ToString("MMM dd, yyyy")</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-primary">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                    <a href="#" class="btn btn-sm btn-warning">
                                        <i class="fas fa-edit"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            <i class="fas fa-info-circle"></i> No audits found. 
            <a href="@Url.Action("CreateAudit", "GovernmentAuditor")" class="alert-link">Create your first audit</a>.
        </div>
    }
</div>
