@model IEnumerable<WorkForceGovProject.Models.Training>
@{
    ViewData["Title"] = "Training Management";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a href="#" class="active">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Training Management</h2>
                <p class="text-muted">Manage and monitor training programs</p>
            </div>
            <a asp-action="CreateTraining" asp-controller="ProgramManager" class="btn btn-primary shadow-sm px-4 fw-bold">
                <i class="bi bi-plus-circle"></i> Create New Training
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <!-- Summary Cards -->
            <div class="row g-4 mb-5">
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-info">🎓</div>
                        <small class="text-uppercase text-muted fw-bold">Total Trainings</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-dark">@Model.Count()</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-success">✅</div>
                        <small class="text-uppercase text-muted fw-bold">Active</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-success">@Model.Count(t => t.Status == "Active")</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-primary">📅</div>
                        <small class="text-uppercase text-muted fw-bold">Upcoming</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-primary">@Model.Count(t => t.StartDate > DateTime.Now)</p>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="stat-card">
                        <div class="icon text-secondary">✔️</div>
                        <small class="text-uppercase text-muted fw-bold">Completed</small>
                        <p class="h3 mb-0 mt-2 fw-bold text-secondary">@Model.Count(t => t.Status == "Completed")</p>
                    </div>
                </div>
            </div>

            <!-- Trainings Table -->
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="px-4 py-3">Training ID</th>
                                <th class="py-3">Title</th>
                                <th class="py-3">Program</th>
                                <th class="py-3">Start Date</th>
                                <th class="py-3">End Date</th>
                                <th class="py-3 text-center">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var training in Model)
                            {
                                <tr>
                                    <td class="px-4 py-3 fw-bold text-primary">#@training.TrainingID</td>
                                    <td class="py-3">
                                        <div class="fw-bold text-dark">@training.Title</div>
                                        <small class="text-muted">@(training.Description.Length > 50 ? training.Description.Substring(0, 50) + "..." : training.Description)</small>
                                    </td>
                                    <td class="py-3">
                                        @if (training.EmploymentProgram != null)
                                        {
                                            <span class="badge bg-info">#@training.ProgramID - @training.EmploymentProgram.Title</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">#@training.ProgramID</span>
                                        }
                                    </td>
                                    <td class="py-3">@training.StartDate.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3">@training.EndDate.ToString("MMM dd, yyyy")</td>
                                    <td class="py-3 text-center">
                                        @if (training.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (training.Status == "Completed")
                                        {
                                            <span class="badge bg-secondary">Completed</span>
                                        }
                                        else if (training.Status == "Pending")
                                        {
                                            <span class="badge bg-warning">Pending</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info">@training.Status</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-3 border shadow-sm">
                <div class="text-center py-5">
                    <div class="mb-4">
                        <i class="bi bi-mortarboard" style="font-size: 4rem; color: #cbd5e1;"></i>
                    </div>
                    <h4 class="text-muted mb-3">No Trainings Found</h4>
                    <p class="text-muted mb-4">No training programs have been created yet.</p>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
        color: #64748b;
    }

    .table tbody tr {
        transition: background-color 0.2s;
    }

    .table tbody tr:hover {
        background-color: #f8fafc;
    }
</style>
