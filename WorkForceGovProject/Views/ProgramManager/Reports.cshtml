@using Microsoft.AspNetCore.Http
@model IEnumerable<WorkForceGovProject.Models.EmploymentProgram>
@{
    ViewData["Title"] = "Reports";
    // Fix for Line 317: Safely get the user name
    var userName = Context.Session.GetString("UserName") ?? "Program Manager";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/Reports.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a href="#" class="active">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Reports & Analytics</h2>
                <p class="text-muted">Comprehensive program reports and insights</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-success shadow-sm px-4 fw-bold" onclick="window.print()">
                    <i class="bi bi-printer"></i> Print
                </button>
            </div>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="row g-4 mb-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-primary text-white p-3">
                        <small>Total Programs</small>
                        <h3 class="fw-bold">@ViewBag.TotalPrograms</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-info text-white p-3">
                        <small>Total Trainings</small>
                        <h3 class="fw-bold">@ViewBag.TotalTrainings</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-success text-white p-3">
                        <small>Benefits Distributed</small>
                        <h3 class="fw-bold">@ViewBag.TotalBenefits</h3>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 bg-warning text-dark p-3">
                        <small>Total Budget</small>
                        <h3 class="fw-bold">@ViewBag.TotalBudget.ToString("C0")</h3>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-3 border shadow-sm p-4 mb-4">
                <h5 class="fw-bold mb-3">Recent Benefit Distributions</h5>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Program</th>
                                <th>Citizen</th>
                                <th class="text-end">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.RecentBenefits != null)
                            {
                                foreach (var benefit in ViewBag.RecentBenefits)
                                {
                                    <tr>
                                        <td>@benefit.Date.ToString("MMM dd, yyyy")</td>
                                        <td>@benefit.EmploymentProgram?.Title</td>
                                        <td>@benefit.Citizen?.Name</td>
                                        <td class="text-end fw-bold text-success">@benefit.Amount.ToString("C")</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="border-top pt-4 mt-5">
                <div class="row">
                    <div class="col-md-6">
                        <p class="text-muted mb-1"><strong>Report Generated:</strong> @DateTime.Now.ToString("MMMM dd, yyyy h:mm tt")</p>
                        <p class="text-muted mb-0"><strong>Generated By:</strong> @userName</p>
                    </div>
                    <div class="col-md-6 text-end">
                        <p class="text-muted mb-1"><strong>Status:</strong> Final Export</p>
                        <p class="text-muted mb-0"><strong>Programs Count:</strong> @ViewBag.TotalPrograms</p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>