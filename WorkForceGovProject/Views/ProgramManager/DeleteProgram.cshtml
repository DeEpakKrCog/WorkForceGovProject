@model WorkForceGovProject.Models.EmploymentProgram
@{
    ViewData["Title"] = "Delete Program";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/CreateProgram.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="active">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Delete Program</h2>
                <p class="text-muted">Confirm program deletion</p>
            </div>
            <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="btn btn-secondary shadow-sm px-4">
                <i class="bi bi-arrow-left"></i> Back to Programs
            </a>
        </div>

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 2rem;"></i>
                <div>
                    <h5 class="mb-1 fw-bold">⚠️ Warning: Permanent Action</h5>
                    <p class="mb-0">You are about to delete this program. This action cannot be undone!</p>
                </div>
            </div>

            <div class="bg-light rounded-3 border p-4 mb-4">
                <h5 class="fw-bold mb-3 text-danger"><i class="bi bi-trash"></i> Program Details</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small fw-bold">Program Title</label>
                        <p class="h5">@Model.Title</p>
                        <label class="text-muted small fw-bold">Status</label>
                        <p><span class="badge bg-primary">@Model.Status</span></p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small fw-bold">Budget</label>
                        <p class="h5 text-success">@Model.Budget.ToString("C")</p>
                    </div>
                </div>
            </div>

            <div class="bg-light rounded-3 border p-3 mb-4">
                <h6 class="fw-bold mb-3">📊 Associated Data (Counts)</h6>
                <div class="row text-center">
                    <div class="col-md-4">
                        <div class="border rounded p-3 bg-white shadow-sm">
                            <i class="bi bi-mortarboard text-info" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@(Model.Trainings?.Count ?? 0)</h4>
                            <small class="text-muted">Trainings</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 bg-white shadow-sm">
                            <i class="bi bi-box-seam text-warning" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@(Model.Resources?.Count ?? 0)</h4>
                            <small class="text-muted">Resources</small>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded p-3 bg-white shadow-sm">
                            <i class="bi bi-gift text-success" style="font-size: 2rem;"></i>
                            <h4 class="mt-2 mb-0">@(Model.Benefits?.Count ?? 0)</h4>
                            <small class="text-muted">Benefits</small>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="DeleteProgram" asp-controller="ProgramManager" method="post">
                <input type="hidden" asp-for="ProgramID" />
                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                    <label class="form-check-label fw-bold" for="confirmDelete">
                        I understand this action is permanent.
                    </label>
                </div>
                <div class="d-flex justify-content-end gap-3">
                    <a asp-action="ProgramManagement" class="btn btn-secondary px-5">Cancel</a>
                    <button type="submit" class="btn btn-danger px-5">Confirm Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>