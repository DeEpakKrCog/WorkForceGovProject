@model WorkForceGovProject.Models.EmploymentProgram
@{
    ViewData["Title"] = "Delete Program";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/CreateProgram.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="active">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Delete Program</h2>
                <p class="text-muted">Confirm program deletion</p>
            </div>
            <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="btn btn-secondary shadow-sm px-4">
                <i class="bi bi-arrow-left"></i> Back to Programs
            </a>
        </div>

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <!-- Danger Alert -->
            <div class="alert alert-danger d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-3" style="font-size: 2rem;"></i>
                <div>
                    <h5 class="mb-1 fw-bold">⚠️ Warning: Permanent Action</h5>
                    <p class="mb-0">You are about to delete this program. This action cannot be undone!</p>
                </div>
            </div>

            <!-- Program Details -->
            <div class="bg-light rounded-3 border p-4 mb-4">
                <h5 class="fw-bold mb-3 text-danger">
                    <i class="bi bi-trash"></i> Program to be Deleted
                </h5>
                
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Program ID</label>
                            <p class="mb-0 h5 text-primary">#@Model.ProgramID</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Program Title</label>
                            <p class="mb-0 h5">@Model.Title</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Status</label>
                            <p class="mb-0">
                                <span class="badge bg-@(Model.Status == "Active" ? "success" : "secondary")">
                                    @Model.Status
                                </span>
                            </p>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Budget</label>
                            <p class="mb-0 h5 text-success">@Model.Budget.ToString("C")</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Duration</label>
                            <p class="mb-0">@Model.StartDate.ToString("MMM dd, yyyy") - @Model.EndDate.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Description</label>
                            <p class="mb-0">@Model.Description</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Impact Warning -->
            <div class="alert alert-warning d-flex align-items-start mb-4" role="alert">
                <i class="bi bi-info-circle-fill me-3" style="font-size: 1.5rem;"></i>
                <div>
                    <h6 class="fw-bold mb-2">⚠️ Deletion Impact:</h6>
                    <ul class="mb-0 small">
                        <li><strong>All associated trainings</strong> will be affected</li>
                        <li><strong>All allocated resources</strong> will be affected</li>
                        <li><strong>All distributed benefits</strong> records may be affected</li>
                        <li><strong>Budget tracking</strong> data will be permanently removed</li>
                        <li><strong>Performance reports</strong> will no longer include this program</li>
                    </ul>
                </div>
            </div>

            <!-- Current Associations -->
            @if (Model.Trainings != null || Model.Resources != null || Model.Benefits != null)
            {
                <div class="bg-light rounded-3 border p-3 mb-4">
                    <h6 class="fw-bold mb-3">📊 Associated Data</h6>
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="border rounded p-3 bg-white">
                                <i class="bi bi-mortarboard text-info" style="font-size: 2rem;"></i>
                                <h4 class="mt-2 mb-0">@(Model.Trainings?.Count ?? 0)</h4>
                                <small class="text-muted">Trainings</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 bg-white">
                                <i class="bi bi-box-seam text-warning" style="font-size: 2rem;"></i>
                                <h4 class="mt-2 mb-0">@(Model.Resources?.Count ?? 0)</h4>
                                <small class="text-muted">Resources</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="border rounded p-3 bg-white">
                                <i class="bi bi-gift text-success" style="font-size: 2rem;"></i>
                                <h4 class="mt-2 mb-0">@(Model.Benefits?.Count ?? 0)</h4>
                                <small class="text-muted">Benefits</small>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Confirmation Form -->
            <form asp-action="DeleteProgram" asp-controller="ProgramManager" method="post">
                <input type="hidden" asp-for="ProgramID" />

                <div class="border-top pt-4 mt-4">
                    <div class="form-check mb-4">
                        <input class="form-check-input" type="checkbox" id="confirmDelete" required>
                        <label class="form-check-label fw-bold" for="confirmDelete">
                            I understand this action is permanent and cannot be undone
                        </label>
                    </div>

                    <div class="d-flex justify-content-end gap-3">
                        <a asp-action="ProgramManagement" asp-controller="ProgramManager" class="btn btn-lg btn-secondary px-5">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-lg btn-danger px-5 shadow-sm">
                            <i class="bi bi-trash"></i> Yes, Delete Program
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Alternative Actions -->
        <div class="bg-light rounded-3 border p-4 mt-4">
            <h5 class="fw-bold mb-3">
                <i class="bi bi-lightbulb text-warning"></i> Consider These Alternatives
            </h5>
            <div class="row">
                <div class="col-md-6">
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-pause-circle text-primary me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Set to Inactive</strong>
                            <p class="mb-0 small text-muted">Temporarily disable the program without losing data</p>
                            <a asp-action="EditProgram" asp-controller="ProgramManager" asp-route-id="@Model.ProgramID" class="btn btn-sm btn-outline-primary mt-2">
                                Edit Instead
                            </a>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex align-items-start mb-3">
                        <i class="bi bi-check-circle text-success me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            <strong>Mark as Completed</strong>
                            <p class="mb-0 small text-muted">Archive the program for historical records</p>
                            <a asp-action="EditProgram" asp-controller="ProgramManager" asp-route-id="@Model.ProgramID" class="btn btn-sm btn-outline-success mt-2">
                                Archive Instead
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .alert-danger {
        border-left: 4px solid #dc3545;
    }

    .alert-warning {
        border-left: 4px solid #ffc107;
    }

    .form-check-input:checked {
        background-color: #dc3545;
        border-color: #dc3545;
    }

    .btn-danger:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(220, 53, 69, 0.4);
    }

    .border.rounded.p-3 {
        transition: all 0.2s ease;
    }

    .border.rounded.p-3:hover {
        transform: translateY(-2px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }
</style>
