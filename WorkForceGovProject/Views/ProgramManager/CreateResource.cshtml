@model WorkForceGovProject.Models.Resource
@{
    ViewData["Title"] = "Create Resource";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/CreateProgram.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager" class="active">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold text-dark mb-2">Create New Resource</h2>
                <p class="text-muted">Add a new resource to a program</p>
            </div>
            <a asp-action="ResourceManagement" asp-controller="ProgramManager" class="btn btn-secondary shadow-sm px-4">
                <i class="bi bi-arrow-left"></i> Back to Resources
            </a>
        </div>

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <form asp-action="CreateResource" asp-controller="ProgramManager" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <!-- Program Selection -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="ProgramID" class="form-label fw-bold">Select Program <span class="text-danger">*</span></label>
                            <select asp-for="ProgramID" class="form-select form-select-lg" asp-items="ViewBag.Programs">
                                <option value="">-- Select Program --</option>
                            </select>
                            <span asp-validation-for="ProgramID" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Resource Type -->
                    <div class="col-md-12">
                        <div class="form-group">
                            <label asp-for="Type" class="form-label fw-bold">Resource Type <span class="text-danger">*</span></label>
                            <input asp-for="Type" class="form-control form-control-lg" placeholder="e.g., Laptops, Software Licenses, Training Materials" />
                            <span asp-validation-for="Type" class="text-danger small"></span>
                            <small class="text-muted">Examples: Laptop Computers, Software Licenses, Training Kits, Safety Equipment</small>
                        </div>
                    </div>

                    <!-- Quantity -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Quantity" class="form-label fw-bold">Quantity <span class="text-danger">*</span></label>
                            <input asp-for="Quantity" type="number" min="0" class="form-control" placeholder="0" />
                            <span asp-validation-for="Quantity" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Status -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Status" class="form-label fw-bold">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-select">
                                <option value="">-- Select Status --</option>
                                <option value="Available" selected>Available</option>
                                <option value="In Use">In Use</option>
                                <option value="Depleted">Depleted</option>
                                <option value="Maintenance">Maintenance</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Information Box -->
                <div class="alert alert-info d-flex align-items-center mt-4" role="alert">
                    <i class="bi bi-info-circle-fill me-2" style="font-size: 1.5rem;"></i>
                    <div>
                        <strong>Note:</strong> Resources are tracked by program. 
                        Specify the type clearly and maintain accurate quantity counts.
                    </div>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                    <a asp-action="ResourceManagement" asp-controller="ProgramManager" class="btn btn-lg btn-outline-secondary px-5">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-lg btn-primary px-5 shadow-sm">
                        <i class="bi bi-check-circle"></i> Create Resource
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
