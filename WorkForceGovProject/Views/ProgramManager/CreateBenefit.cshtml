@model WorkForceGovProject.Models.Benefit
@{
    ViewData["Title"] = "Create Benefit";
}

<link rel="stylesheet" href="~/css/Dashboard.css" />
<link rel="stylesheet" href="~/css/CreateProgram.css" />

<div class="dashboard-container">
    <div class="sidebar-nav d-none d-md-block shadow">
        <a asp-action="Dashboard" asp-controller="ProgramManager">🏠 Dashboard</a>
        <a asp-action="ProgramManagement" asp-controller="ProgramManager">📋 Programs</a>
        <a asp-action="TrainingManagement" asp-controller="ProgramManager">🎓 Trainings</a>
        <a asp-action="BudgetMonitoring" asp-controller="ProgramManager">💰 Budget</a>
        <a asp-action="PerformanceTracking" asp-controller="ProgramManager">📊 Performance</a>
        <a asp-action="ResourceManagement" asp-controller="ProgramManager">📦 Resources</a>
        <a asp-action="BenefitManagement" asp-controller="ProgramManager" class="active">🎁 Benefits</a>
        <a asp-action="Reports" asp-controller="ProgramManager">📈 Reports</a>
        <a asp-action="Logout" asp-controller="Account" class="text-danger mt-5 fw-bold">🚪 Sign Out</a>
    </div>

    <div class="main-content">
        @{
            ViewBag.PageTitle = "Create New Benefit";
            ViewBag.PageSubtitle = "Distribute a benefit to a citizen";
            ViewBag.BackLink = "BenefitManagement";
            ViewBag.BackController = "ProgramManager";
            ViewBag.BackText = "Back to Benefits";
        }
        @await Html.PartialAsync("_PageHeader")

        <div class="bg-white rounded-3 border shadow-sm p-4">
            <form asp-action="CreateBenefit" asp-controller="ProgramManager" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="row g-3">
                    <!-- Program Selection -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="ProgramID" class="form-label fw-bold">Select Program <span class="text-danger">*</span></label>
                            <select asp-for="ProgramID" class="form-select form-select-lg" asp-items="ViewBag.Programs">
                                <option value="">-- Select Program --</option>
                            </select>
                            <span asp-validation-for="ProgramID" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Citizen Selection -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="CitizenID" class="form-label fw-bold">Select Citizen <span class="text-danger">*</span></label>
                            <div class="d-flex gap-2">
                                <select asp-for="CitizenID" class="form-select form-select-lg flex-grow-1" asp-items="ViewBag.Citizens">
                                    <option value="">-- Select Citizen --</option>
                                </select>
                                <a asp-action="CreateCitizen" asp-controller="Citizen" target="_blank" class="btn btn-outline-primary" title="Register New Citizen">
                                    <i class="bi bi-person-plus"></i>
                                </a>
                            </div>
                            <span asp-validation-for="CitizenID" class="text-danger small"></span>
                            <small class="text-muted">Don't see the citizen? <a asp-action="CreateCitizen" asp-controller="Citizen" target="_blank" class="fw-bold">Register a new citizen</a></small>
                        </div>
                    </div>

                    <!-- Benefit Amount -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Amount" class="form-label fw-bold">Benefit Amount <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="Amount" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Amount" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Benefit Type -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Type" class="form-label fw-bold">Benefit Type <span class="text-danger">*</span></label>
                            <select asp-for="Type" class="form-select">
                                <option value="">-- Select Type --</option>
                                <option value="Training Stipend">Training Stipend</option>
                                <option value="Equipment Grant">Equipment Grant</option>
                                <option value="Certification Bonus">Certification Bonus</option>
                                <option value="Certification Fee">Certification Fee</option>
                                <option value="Safety Equipment">Safety Equipment</option>
                                <option value="Business Grant">Business Grant</option>
                                <option value="Marketing Support">Marketing Support</option>
                                <option value="Startup Capital">Startup Capital</option>
                                <option value="Cash Assistance" selected>Cash Assistance</option>
                                <option value="Transportation Allowance">Transportation Allowance</option>
                                <option value="Childcare Support">Childcare Support</option>
                                <option value="Housing Assistance">Housing Assistance</option>
                            </select>
                            <span asp-validation-for="Type" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Benefit Date -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="Date" class="form-label fw-bold">Benefit Date <span class="text-danger">*</span></label>
                            <input asp-for="Date" type="date" class="form-control" />
                            <span asp-validation-for="Date" class="text-danger small"></span>
                        </div>
                    </div>
                </div>

                <!-- Information Box -->
                <div class="alert alert-warning d-flex align-items-center mt-4" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2" style="font-size: 1.5rem;"></i>
                    <div>
                        <strong>Important:</strong> This benefit will be deducted from the selected program's budget. 
                        Verify the amount and ensure sufficient funds are available.
                    </div>
                </div>

                <!-- Budget Information -->
                <div class="bg-light rounded-3 border p-3 mt-3">
                    <h6 class="fw-bold mb-2">💡 Benefit Guidelines</h6>
                    <ul class="mb-0 small">
                        <li>Ensure the citizen is enrolled in the selected program</li>
                        <li>Verify program budget has sufficient remaining funds</li>
                        <li>Document the purpose of the benefit for audit trails</li>
                        <li>Benefits are tracked against program budgets automatically</li>
                    </ul>
                </div>

                <!-- Form Buttons -->
                <div class="d-flex justify-content-end gap-3 mt-4 pt-3 border-top">
                    <a asp-action="BenefitManagement" asp-controller="ProgramManager" class="btn btn-lg btn-outline-secondary px-5">
                        <i class="bi bi-x-circle"></i> Cancel
                    </a>
                    <button type="submit" class="btn btn-lg btn-success px-5 shadow-sm">
                        <i class="bi bi-check-circle"></i> Distribute Benefit
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
